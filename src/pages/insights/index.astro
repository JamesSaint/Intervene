---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InsightCard from '../../components/InsightCard.astro';

const insights = [
  {
    kicker: 'Note',
    title: 'Accountability theatre: the named SMF without halt authority',
    dek: 'A designated executive who cannot stop the system is a name on a chart, not a control. AGDA™ measures the pairing.',
    href: '/insights/accountability-theatre/',
  },
  {
    kicker: 'Note',
    title: 'Coincidence is not a margin',
    dek: 'An absence of incidents is evidence of untested exposure, not effective control. Quiet is not the same as safe.',
    href: '/insights/coincidence-is-not-a-margin/',
  },
  {
    kicker: 'Note',
    title: 'The 36-hour window, and why the board hears last',
    dek: 'Authority travels upward through people who cannot act. By the time it reaches the board, the cheap intervention has passed.',
    href: '/insights/the-thirty-six-hour-window/',
  },
];
---

<BaseLayout
  title="Evidence Notes · Intervene"
  description="Board-grade notes on Intervention Readiness: where accountability, escalation and quiet operating histories fail to evidence intervention capability."
  current="insights"
  pageType="CollectionPage"
>
  <section class="hero">
    <div class="wrap-narrow">
      <h1 class="h1 reveal">Evidence notes on <em>intervention failure.</em></h1>
      <p class="lede muted reveal">
        Where Intervention Readiness fails, and why control frameworks often
        miss it. Written for the people accountable when a consequential system
        runs on.
      </p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="insights-list" role="list">
        {insights.map((a) => (
          <InsightCard title={a.title} dek={a.dek} href={a.href} kicker={a.kicker} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 96px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 18ch; }
  .hero .lede { margin-top: 32px; max-width: 52ch; }
  @media (max-width: 880px) {
    .hero { padding-top: 88px; padding-bottom: 64px; }
  }
</style>
