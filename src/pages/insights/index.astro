---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InsightCard from '../../components/InsightCard.astro';

const insights = [
  {
    kicker: 'Note',
    title: 'Accountability theatre: the named SMF without halt authority',
    dek: 'A designated executive who cannot stop the system is a name on a chart, not a control. AGDA penalises the pairing.',
    href: '/Intervene/insights/accountability-theatre/',
  },
  {
    kicker: 'Note',
    title: 'Coincidence is not a margin',
    dek: 'An absence of incidents is evidence of untested exposure, not effective control. Quiet is not the same as safe.',
    href: '/Intervene/insights/coincidence-is-not-a-margin/',
  },
  {
    kicker: 'Note',
    title: 'The 36-hour window, and why the board hears last',
    dek: 'Authority travels upward through people who cannot act. By the time it reaches the board, the cheap intervention has passed.',
    href: '/Intervene/insights/the-thirty-six-hour-window/',
  },
];
---

<BaseLayout
  title="Insights · Intervene"
  description="Board-grade notes on intervention readiness: accountability theatre, the cost of mistaking quiet for safe, and why escalation chains run slower than the harm they govern."
  current="insights"
>
  <section class="hero">
    <div class="wrap-narrow">
      <h1 class="h1 reveal">Notes from the <em>practice.</em></h1>
      <p class="lede muted reveal">
        Where intervention readiness fails, and why frameworks miss it.
        Written for the people accountable when a consequential system runs on.
      </p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="card-grid insights-grid" role="list">
        {insights.map((a) => (
          <InsightCard title={a.title} dek={a.dek} href={a.href} kicker={a.kicker} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 96px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 16ch; }
  .hero .lede { margin-top: 32px; max-width: 52ch; }
  @media (max-width: 880px) {
    .hero { padding-top: 88px; padding-bottom: 64px; }
  }
</style>
