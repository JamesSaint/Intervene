---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChainFlow from '../../components/ChainFlow.astro';
import EvidenceCap from '../../components/EvidenceCap.astro';
import ChainCeiling from '../../components/ChainCeiling.astro';

const dimensions = [
  { name: 'Signal',          q: 'Can the system surface the conditions that need attention, in time?' },
  { name: 'Escalation',      q: 'Does the signal reach an authority before the window to act has closed?' },
  { name: 'Decision',        q: 'Can the decision be made under pressure with incomplete information?' },
  { name: 'Intervention',    q: 'Can the action take effect before the consequence compounds?' },
  { name: 'Accountability',  q: 'Is responsibility real in practice, not only on paper?' },
  { name: 'Human oversight', q: 'Is oversight informed and capable of altering outcomes?' },
  { name: 'Auditability',    q: 'Is the decision trail complete, reliable, and defensible later?' },
  { name: 'Capacity',        q: 'Are the people and authority present when the moment arrives?' },
];

const stances = [
  { h: 'Coincidence is not a margin.',                       p: 'Absence of incidents is evidence of untested exposure, not effective controls.' },
  { h: 'Accountability cannot mask weak oversight.',         p: 'Naming an SMF4 without halt authority is governance theatre. The engine penalises the pairing.' },
  { h: 'Paper evidence caps at amber.',                      p: 'Policy without drill maxes at red. Drill without production maxes at amber. Green needs stress.' },
  { h: 'Confidence must not exceed evidence.',               p: 'High confidence against low-grade evidence demotes the dimension. Overconfidence is a governance failure.' },
];

const engagement = [
  { h: 'Exposure.',         p: 'We map the system, the decision context, the risk scenario, and the assumed intervention path. Written scope before scoring.' },
  { h: 'Reality Testing.',  p: 'We score every dimension against evidence grade. Chain ceiling and contradictions surface here.' },
  { h: 'Decision Support.', p: 'Attested Failure Exposure Report. Delivered direct to the Board. Remediation prioritised. Not implemented by us.' },
];

const docs = [
  { h: 'AGDA Thesis',              p: 'The intellectual position. Eight falsifiable claims.' },
  { h: 'Failure Mode Catalogue',   p: 'Forty canonical AI governance failure modes. Each citeable.' },
  { h: 'Corpus Governance',        p: 'How calibration evidence is built, held, and retired.' },
  { h: 'Rater Protocol',           p: 'The protocol external raters follow against the corpus.' },
];
---

<BaseLayout
  title="Method · AGDA"
  description="AGDA scores intervention capability against evidence. Published methodology. Cryptographically attested output."
  current="method"
  noindex={true}
>
  <section class="hero">
    <div class="wrap">
      <h1 class="h1 reveal">A deterministic engine, <em>not a methodology deck.</em></h1>
      <p class="lede muted reveal">
        Capability against evidence, not intention. Same inputs, same outputs.
        Signed.
      </p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Four stages. The chain is the control.</h2>
      <ChainFlow />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Eight dimensions.</h2>
      <p class="lede muted">
        The four chain stages, plus the four conditions that determine whether
        each stage holds.
      </p>
      <ul class="dim-grid reveal" role="list">
        {dimensions.map((d) => (
          <li>
            <h3 class="h3">{d.name}</h3>
            <p class="body muted">{d.q}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Paper evidence caps at amber.</h2>
      <p class="lede muted">
        AGDA enforces an evidence ceiling before weighting. The
        lowest-evidence claim anchors the dimension.
      </p>
      <EvidenceCap />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">A downstream stage cannot score above upstream, plus one.</h2>
      <p class="lede muted">
        Operational topology, not heuristic. Claimed downstream strength on a
        weak upstream is structural fiction.
      </p>
      <ChainCeiling />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Four positions the engine takes.</h2>
      <ul class="stances" role="list">
        {stances.map((s) => (
          <li>
            <h3 class="h3">{s.h}</h3>
            <p class="body muted">{s.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">Every verdict is signed.</h2>
      <p class="lede muted">
        Ed25519 envelope. Same inputs, same outputs, bound to a specific engine
        version. Verifiable by an audit committee using a committed public key.
      </p>
      <pre class="envelope" aria-label="Attestation envelope example"><code>{`engineVersion   1.2.0
engineHash      sha256:b2c8a1d…e7f2916
inputHash       sha256:47a2e19…cd8b103
outputHash      sha256:91f4c02…a6d0d4e
keyId           2026-04-22-1e7c3c2c
scoredAt        2026-05-14T09:47:12.334Z
signature       ed25519:M4Gb2ZqAfD…pLQX7w`}</code></pre>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three stages of engagement.</h2>
      <ul class="engagement" role="list">
        {engagement.map((s) => (
          <li>
            <h3 class="h3">{s.h}</h3>
            <p class="body muted">{s.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Published methodology.</h2>
      <p class="lede muted">
        Public. Citeable. Falsifiable. The calibration is held private under
        standard trade-secret discipline.
      </p>
      <ul class="docs" role="list">
        {docs.map((d) => (
          <li>
            <h3 class="h3">{d.h}</h3>
            <p class="body muted">{d.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block tight">
    <div class="wrap-narrow cta-band">
      <h2 class="h2">A sample report is published.</h2>
      <p class="body muted">
        Redacted from a banking case: material credit model, escalation break,
        PRA SS1/23 §6 exposure.
      </p>
      <div class="cta">
        <a href="/Intervene/sample-report/" class="btn">Open the sample report</a>
        <a href="/Intervene/contact/" class="btn-ghost">Request a discussion</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 18ch; }
  .hero .lede { margin-top: 32px; max-width: 48ch; }

  .block .h2 { max-width: 22ch; }
  .block .lede { margin-top: 16px; max-width: 56ch; }

  .dim-grid {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 48px;
    border-top: 1px solid var(--ink);
    /* override .reveal defaults so the parent does not animate;
       its children animate individually below. */
    opacity: 1;
    transform: none;
  }
  .dim-grid > li {
    padding: 40px 0;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 12px;
    align-content: start;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 480ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dim-grid .h3 { font-size: 22px; margin: 0; }
  .dim-grid p { max-width: 28ch; margin: 0; }

  .dim-grid.in > li { opacity: 1; transform: none; }
  .dim-grid.in > li:nth-child(1) { transition-delay: 0ms; }
  .dim-grid.in > li:nth-child(2) { transition-delay: 80ms; }
  .dim-grid.in > li:nth-child(3) { transition-delay: 160ms; }
  .dim-grid.in > li:nth-child(4) { transition-delay: 240ms; }
  .dim-grid.in > li:nth-child(5) { transition-delay: 320ms; }
  .dim-grid.in > li:nth-child(6) { transition-delay: 400ms; }
  .dim-grid.in > li:nth-child(7) { transition-delay: 480ms; }
  .dim-grid.in > li:nth-child(8) { transition-delay: 560ms; }

  @media (prefers-reduced-motion: reduce) {
    .dim-grid > li {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  .stances {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px 80px;
    max-width: 1080px;
  }
  .stances > li { display: grid; gap: 12px; }
  .stances p { max-width: 44ch; margin: 0; }

  .envelope {
    margin: 48px 0 0;
    padding: 32px;
    background: var(--paper-soft);
    border: 1px solid var(--hair);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.8;
    overflow-x: auto;
    white-space: pre;
  }
  .envelope code { font-family: inherit; }

  .engagement,
  .docs {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 64px;
  }
  .docs { grid-template-columns: 1fr 1fr 1fr 1fr; gap: 48px; }
  .engagement > li,
  .docs > li { display: grid; gap: 12px; align-content: start; }
  .engagement p,
  .docs p { max-width: 32ch; margin: 0; }

  .cta-band { text-align: left; }
  .cta-band .body { margin: 16px 0 32px; max-width: 56ch; }
  .cta-band .cta { display: flex; flex-wrap: wrap; gap: 16px; }

  @media (max-width: 880px) {
    .hero { padding-top: 88px; padding-bottom: 88px; }
    .dim-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 32px;
    }
    .stances { grid-template-columns: 1fr; gap: 48px; }
    .engagement { grid-template-columns: 1fr; gap: 48px; }
    .docs { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 560px) {
    .dim-grid {
      grid-template-columns: 1fr;
      column-gap: 0;
    }
    .docs { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
