---
// Permanent redirect. /method/ moved to /methodology/ when AGDA (the
// category) was split from the methodology (the engine). Static build,
// so this is a meta-refresh stub plus canonical to the new location.
const target = '/Intervene/methodology/';
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Moved · Methodology · AGDA</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={`https://jamessaint.github.io${target}`} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>This page has moved to <a href={target}>Methodology</a>.</p>
  </body>
</html>
