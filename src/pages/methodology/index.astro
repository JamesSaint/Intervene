---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChainFlow from '../../components/ChainFlow.astro';
import EvidenceCap from '../../components/EvidenceCap.astro';
import ChainCeiling from '../../components/ChainCeiling.astro';
import ProofMarks from '../../components/ProofMarks.astro';
import { markAgda } from '../../lib/marks';

const dimensions = [
  { name: 'Detect',          q: 'Can the system surface the conditions that need attention, in time?' },
  { name: 'Escalate',        q: 'Does the signal reach an authority before the window to act has closed?' },
  { name: 'Decide',          q: 'Can the decision be made under pressure with incomplete information?' },
  { name: 'Intervene',       q: 'Can the action take effect before the consequence compounds?' },
  { name: 'Accountability',  q: 'Is responsibility real in practice, not only on paper?' },
  { name: 'Human oversight', q: 'Is oversight informed and capable of altering outcomes?' },
  { name: 'Auditability',    q: 'Is the decision trail complete, reliable, and defensible later?' },
  { name: 'Capacity',        q: 'Are the people and authority present when the moment arrives?' },
];

const stances = [
  { h: 'Coincidence is not a margin.',                       p: 'Absence of incidents is evidence of untested exposure, not effective controls.' },
  { h: 'Accountability cannot mask weak oversight.',         p: 'Naming an SMF4 without halt authority is governance theatre. The engine measures the pairing.' },
  { h: 'Evidence quality constrains confidence.',            p: 'Policy, drill, production and stress evidence carry different weight. High confidence needs evidence that has survived pressure.' },
  { h: 'Confidence must not exceed evidence.',               p: 'High confidence against weak evidence is demoted. Overconfidence is an assurance failure.' },
];

const docs = [
  { h: 'AGDA™ Thesis',             p: 'The intellectual position. Eight falsifiable claims.' },
  { h: 'Failure Mode Catalogue',   p: 'Forty canonical intervention failure modes. Each citeable.' },
  { h: 'Corpus Governance',        p: 'How calibration evidence is built, held, and retired.' },
  { h: 'Rater Protocol',           p: 'The protocol external raters follow against the corpus.' },
];
---

<BaseLayout
  title="How AGDA™ Measures Intervention Readiness · Intervene"
  description="AGDA™ measures Intervention Readiness against evidence: detect, escalate, decide, intervene, evidence-quality constraints, chain propagation, and a signed verdict a regulator can verify."
  current="methodology"
  ogImage="/assets/og/og-methodology.png"
>
  <section class="hero">
    <div class="wrap">
      <h1 class="h1 reveal">Measurement, <em>not assertion.</em></h1>
      <p class="lede muted reveal">
        The engine behind the verdict. Intervention capability against
        evidence, not intention. Same inputs, same outputs. Signed and
        independently verifiable.
      </p>
      <div class="hero-proof reveal"><ProofMarks /></div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">The intervention chain. <em>The chain is the control.</em></h2>
      <p class="lede muted">
        Detect, Escalate, Decide, Intervene. Four sequential stages running
        against a reversibility window. The engine measures whether the
        cumulative chain completes before harm becomes irreversible.
      </p>
      <ChainFlow />

      <ul class="verdicts" role="list">
        <li>
          <span class="mono verdict-name">Before impact</span>
          <p class="body">The chain completes in time under the observed conditions.</p>
        </li>
        <li>
          <span class="mono verdict-name">At risk</span>
          <p class="body">The chain completes, but within a margin that operational noise can erode.</p>
        </li>
        <li>
          <span class="mono verdict-name warn">After impact</span>
          <p class="body">The chain does not complete in time. Harm is irreversible before intervention can land.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Eight dimensions.</h2>
      <p class="lede muted">
        The four chain stages, plus the four conditions that determine whether
        each stage holds.
      </p>
      <ul class="dim-grid reveal" role="list">
        {dimensions.map((d) => (
          <li>
            <h3 class="h3">{d.name}</h3>
            <p class="body muted">{d.q}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Evidence quality constrains confidence.</h2>
      <p class="lede muted">
        <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> does not let confidence outrun proof. Policy, drill,
        production and stress evidence are treated differently before the
        engine propagates the chain.
      </p>
      <EvidenceCap />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">A downstream stage cannot measure above upstream, plus one.</h2>
      <p class="lede muted">
        Operational topology, not heuristic. Claimed downstream strength on a
        weak upstream is structural fiction.
      </p>
      <ChainCeiling />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Four positions the engine takes.</h2>
      <ul class="stances" role="list">
        {stances.map((s) => (
          <li>
            <h3 class="h3">{s.h}</h3>
            <p class="body muted">{s.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">A regulator can verify. <em>Without contacting us.</em></h2>
      <p class="lede muted">
        Every formal AGDA™ SEDI assessment ships with a signed JSON regulator
        bundle. The attestation envelope binds the result to engine,
        methodology, rubric, input, output and manifest hashes. The verify
        command runs locally under Node.js 18+. The customer does not depend on
        us to read what we produced for them.
      </p>
      <pre class="envelope" aria-label="Attestation envelope example"><code>{`attestationVersion 1.2
engineVersion      2.0.6
engineHash         17594a80…60355e50
transformVersion   N/A
catalogueVersion   1.0
methodologyVersion 1.3.0
rubricVersion      1.3.0
keyId              2026-05-02-d7e5468e
scoredAt           2026-05-14T09:47:12.334Z
inputHash          47a2e19c…103e4f8d
outputHash         91f4c02a…d4e7ad91
manifestHash       36b45cbe…3edc1c12
signature          M4Gb2ZqAfD…pLQX7w==`}</code></pre>
      <a href="/verify/" class="services-link">How the verify path works <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Intervention scenarios.</h2>
      <p class="lede muted">
        A what-if console for the resilience function. Test whether proposed
        changes improve intervention timing before committing to a remediation
        path. Stronger Intervention Readiness supports deployment decisions
        with greater confidence.
      </p>

      <ul class="labs-grid" role="list">
        <li>
          <h3 class="h3">Counterfactual chains.</h3>
          <p class="body muted">Move a control upstream, change a quorum rule, add an on-call halt authority. The console recomputes the chain against the same harm window.</p>
        </li>
        <li>
          <h3 class="h3">Sensitivity testing.</h3>
          <p class="body muted">Vary the reversibility window or the trigger scenario. See which stages bind and which slack out.</p>
        </li>
        <li>
          <h3 class="h3">Board readout prep.</h3>
          <p class="body muted">Walk an audit committee through three remediation options with the verdict on each, before committing to a single path.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Published measurement basis.</h2>
      <p class="lede muted">
        Public. Citeable. Falsifiable. The calibration is held private under
        standard trade-secret discipline. Four canonical documents anchor the
        practice.
      </p>
      <ul class="docs" role="list">
        {docs.map((d) => (
          <li>
            <h3 class="h3" set:html={markAgda(d.h)} />
            <p class="body muted">{d.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="block tight">
    <div class="wrap-narrow cta-band">
      <h2 class="h2">A sample verdict is published.</h2>
      <p class="body muted">
        An illustrative historical banking sample: material credit model,
        escalation break, PRA SS1/23 §6 exposure. It shows the verdict,
        evidence and report structure. The current production attestation
        format is documented on the verify page.
      </p>
      <div class="cta">
        <a href="/sample-report/" class="btn">View sample verdict</a>
        <a href="/contact/" class="btn-ghost">Book a conversation</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 22ch; }
  .hero .lede { margin-top: 32px; max-width: 56ch; }
  .hero-proof { margin-top: 36px; }

  .block .h2 { max-width: 28ch; }
  .block .lede { margin-top: 16px; max-width: 56ch; }

  /* Intervention-chain verdict states */
  .verdicts {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px 48px;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
  }
  .verdicts > li { display: grid; gap: 8px; align-content: start; }
  .verdict-name {
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
  }
  .verdict-name.warn { color: var(--warn); }
  .verdicts p { max-width: 36ch; margin: 0; }

  /* Labs grid */
  .labs-grid {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 56px;
    border-top: 1px solid var(--hair-strong);
    padding-top: 32px;
  }
  .labs-grid > li { display: grid; gap: 12px; align-content: start; }
  .labs-grid p { max-width: 36ch; margin: 0; }

  /* Inline arrow link */
  .services-link {
    display: inline-block;
    margin-top: 32px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid var(--hair-strong);
    padding-bottom: 2px;
    transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .services-link:hover { border-color: var(--accent); }

  .dim-grid {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 48px;
    border-top: 1px solid var(--hair-strong);
    opacity: 1;
    transform: none;
  }
  .dim-grid > li {
    padding: 40px 0;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 12px;
    align-content: start;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 480ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .dim-grid .h3 { font-size: 22px; margin: 0; }
  .dim-grid p { max-width: 28ch; margin: 0; }

  .dim-grid.in > li { opacity: 1; transform: none; }
  .dim-grid.in > li:nth-child(1) { transition-delay: 0ms; }
  .dim-grid.in > li:nth-child(2) { transition-delay: 80ms; }
  .dim-grid.in > li:nth-child(3) { transition-delay: 160ms; }
  .dim-grid.in > li:nth-child(4) { transition-delay: 240ms; }
  .dim-grid.in > li:nth-child(5) { transition-delay: 320ms; }
  .dim-grid.in > li:nth-child(6) { transition-delay: 400ms; }
  .dim-grid.in > li:nth-child(7) { transition-delay: 480ms; }
  .dim-grid.in > li:nth-child(8) { transition-delay: 560ms; }

  @media (prefers-reduced-motion: reduce) {
    .dim-grid > li {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  .stances {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px 80px;
    max-width: 1080px;
  }
  .stances > li { display: grid; gap: 12px; }
  .stances p { max-width: 44ch; margin: 0; }

  .envelope {
    margin: 48px 0 0;
    padding: 32px;
    background: var(--paper-soft);
    border: 1px solid var(--hair);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.8;
    overflow-x: auto;
    white-space: pre;
  }
  .envelope code { font-family: inherit; }

  .docs {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .docs > li { display: grid; gap: 12px; align-content: start; }
  .docs p { max-width: 32ch; margin: 0; }

  .cta-band { text-align: left; }
  .cta-band .body { margin: 16px 0 32px; max-width: 56ch; }
  .cta-band .cta { display: flex; flex-wrap: wrap; gap: 16px; }

  @media (max-width: 880px) {
    .hero { padding-top: 88px; padding-bottom: 88px; }
    .dim-grid { grid-template-columns: 1fr 1fr; column-gap: 32px; }
    .stances { grid-template-columns: 1fr; gap: 48px; }
    .docs { grid-template-columns: 1fr 1fr; gap: 32px; }
    .verdicts { grid-template-columns: 1fr; gap: 32px; }
    .labs-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 560px) {
    .dim-grid { grid-template-columns: 1fr; column-gap: 0; }
    .docs { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
