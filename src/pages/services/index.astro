---
import BaseLayout from '../../layouts/BaseLayout.astro';

const reportLayers = [
  {
    name: 'Executive',
    audience: 'CRO, board, audit committee',
    body: 'Headline verdict, viability status, critical failure summary, regulatory exposure, priority actions. One-page decision frame.',
  },
  {
    name: 'Operational',
    audience: 'Head of Operational Resilience, Head of Model Risk',
    body: 'Plus temporal gating across eight gates with reasons, causal chain with timing, scenario impact, SEDI chain, dimension scores.',
  },
  {
    name: 'Specialist',
    audience: 'AI Governance lead, regulator liaison',
    body: 'Plus irreversibility profile, failure profiles, single points of failure, framework pressure, regulatory mapping, JSON export, attestation envelope.',
  },
];

const tiers = [
  {
    name: 'Pilot',
    framing: 'First engagement. One system.',
    formats: [
      { label: 'Short pilot · 4 weeks · 1 system',         gbp: '£95,000',   eur: '€110,000', usd: '$125,000' },
      { label: '90-day structured pilot · 1 system',       gbp: '£120,000',  eur: '€140,000', usd: '$155,000' },
      { label: '90-day structured pilot · 2 systems',      gbp: '£175,000',  eur: '€205,000', usd: '$225,000' },
      { label: '90-day structured pilot · 3 systems',      gbp: '£225,000',  eur: '€265,000', usd: '$290,000' },
    ],
    includes: 'Failure Exposure Report at all three audience layers, regulator bundle, attestation envelope, Labs Intervention Simulator access for 5 named operators, 90-minute board readout, signed close-out memo.',
  },
  {
    name: 'Annual subscription',
    framing: 'Post-pilot conversion. Standing engagement.',
    formats: [
      { label: 'Annual subscription',     gbp: '£180,000 / yr', eur: '€210,000 / yr', usd: '$235,000 / yr' },
      { label: 'Equivalent quarterly',    gbp: '£45,000 / qtr', eur: '€52,500 / qtr', usd: '$58,750 / qtr' },
    ],
    includes: 'Five named operator seats, two assessed systems per year, engine-hash pinning, quarterly re-run rights on each system, annual board-readout session.',
  },
  {
    name: 'Enterprise master',
    framing: 'Multi-system, multi-entity. Custom-scoped.',
    formats: [
      { label: 'Annual, custom-scoped',   gbp: '£350,000+ / yr', eur: '€410,000+ / yr', usd: '$450,000+ / yr' },
    ],
    includes: 'Up to 15 named operator seats, up to 5 assessed systems per year, 40 regulator-liaison hours, quarterly portfolio review with group CRO, two annual board-readout sessions, multi-entity invoicing, designated AGDA operator.',
    triggers: 'Triggers: 9+ assessed systems per year, 20+ seats, or 2+ legal entities under a single group.',
  },
];

const addons = [
  { label: 'Additional assessed system, post-pilot',                  gbp: '£55,000',       eur: '€65,000',     usd: '$72,000' },
  { label: 'Additional re-run, beyond quarterly included in Annual',   gbp: '£20,000',       eur: '€23,000',     usd: '$25,000' },
  { label: 'Additional named Labs operator',                          gbp: '£3,000 / term', eur: '€3,500 / term', usd: '$4,000 / term' },
  { label: 'Board-readout session, remote',                           gbp: '£12,000',       eur: '€14,000',     usd: '$15,500' },
  { label: 'Board-readout session, on-site',                          gbp: '£18,000',       eur: '€21,000',     usd: '$23,000' },
  { label: 'Regulator bundle, post-engine-version change',            gbp: '£6,000',        eur: '€7,000',      usd: '$7,500' },
];

const services = [
  { label: 'Operator certification, internal governance team (up to 2 raters)', gbp: '£55,000',     eur: '€64,000',     usd: '$70,000' },
  { label: 'Operator certification, advisory firm (firm-level)',                gbp: '£85,000',     eur: '€99,000',     usd: '$108,000' },
  { label: 'Advisory firm annual renewal',                                       gbp: '£25,000 / yr', eur: '€29,000 / yr', usd: '$32,000 / yr' },
  { label: 'Regulator-liaison block (20 hours, per quarter)',                   gbp: '£18,000',     eur: '€21,000',     usd: '$23,000' },
];

const notProduct = [
  { h: 'Not a maturity framework.',  p: 'We do not score governance artefact completeness. We score timing and evidence grade against a harm window.' },
  { h: 'Not a compliance checklist.', p: 'Regulatory exposure is a mechanical output of the assessment. We do not score adherence to clauses.' },
  { h: 'Not a risk score.',          p: 'AGDA produces a binary verdict: can you intervene in time? It feeds a risk register. It does not substitute for one.' },
  { h: 'Not a monitoring tool.',     p: 'AGDA examines governance once per assessment. Runtime monitoring is a different product category.' },
];

const benchmarks = [
  { h: 'A senior model risk hire.',              p: 'Fully loaded cost £200,000 to £260,000. Output is not deterministic, not signed, not independently verifiable.' },
  { h: 'A Big Four governance review.',          p: '£200,000 to £500,000 per system, one-time. The output is a consulting report, not a signed artefact.' },
  { h: 'A regulatory advisory retainer.',        p: '£300,000 to £800,000 per year. Our regulatory exposure output is more specific and independently verifiable.' },
];
---

<BaseLayout
  title="Services · Intervene"
  description="A deterministic answer to one question: if one of your AI systems goes wrong right now, can you stop it before harm becomes irreversible? Signed. Verifiable. Pinned to a locked engine version."
  current="services"
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <h1 class="h1 reveal">
        One question. <em>One signed answer.</em>
      </h1>
      <p class="lede muted reveal">
        If one of your AI systems goes wrong right now, can you stop it before
        harm becomes irreversible? AGDA gives you a deterministic, signed
        answer, bound to a locked engine version, that an audit committee can
        defend and a regulator can verify without contacting us.
      </p>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">What every engagement produces.</h2>
      <p class="lede muted">
        A single structured output: the AGDA Reports Failure Exposure Report.
        Three audience layers, all bound to the same engine hash and
        attestation envelope.
      </p>

      <ul class="layers reveal" role="list">
        {reportLayers.map((l) => (
          <li>
            <h3 class="h3">{l.name}.</h3>
            <span class="mono layer-aud">{l.audience}</span>
            <p class="body muted">{l.body}</p>
          </li>
        ))}
      </ul>

      <div class="labs">
        <h3 class="h3">Labs Intervention Simulator.</h3>
        <p class="body muted">
          A what-if console for the resilience function. Test intervention
          timing against hypothetical scenarios without re-running the full
          assessment. Included with every tier.
        </p>
      </div>
    </div>
  </section>

  <!-- THREE TIERS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three tiers. <em>Priced per assessment.</em></h2>
      <p class="lede muted">
        The commercial unit is the assessment, not the seat. Customers expand
        by assessing more systems, not by adding users.
      </p>

      <ol class="tiers" role="list">
        {tiers.map((t) => (
          <li class="tier reveal">
            <div class="tier-head">
              <h3 class="h3">{t.name}.</h3>
              <span class="mono tier-framing">{t.framing}</span>
            </div>

            <ul class="formats" role="list">
              {t.formats.map((f) => (
                <li>
                  <span class="format-label">{f.label}</span>
                  <span class="format-price">
                    <span class="price-gbp">{f.gbp}</span>
                    <span class="price-alt mono">{f.eur} · {f.usd}</span>
                  </span>
                </li>
              ))}
            </ul>

            <p class="body muted tier-includes">
              <strong>Includes.</strong> {t.includes}
            </p>
            {t.triggers && (
              <p class="mono tier-triggers">{t.triggers}</p>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ADD-ONS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Add-ons.</h2>
      <p class="lede muted">
        Any tier. Priced per unit. No volume discount on the first deal in a
        sector.
      </p>

      <ul class="rate-card" role="list">
        {addons.map((a) => (
          <li>
            <span class="rate-label">{a.label}</span>
            <span class="rate-price">
              <span class="price-gbp">{a.gbp}</span>
              <span class="price-alt mono">{a.eur} · {a.usd}</span>
            </span>
          </li>
        ))}
      </ul>

      <h3 class="h3 services-head">Professional services.</h3>
      <ul class="rate-card" role="list">
        {services.map((a) => (
          <li>
            <span class="rate-label">{a.label}</span>
            <span class="rate-price">
              <span class="price-gbp">{a.gbp}</span>
              <span class="price-alt mono">{a.eur} · {a.usd}</span>
            </span>
          </li>
        ))}
      </ul>

      <p class="body muted footnote">
        Prices shown in GBP, EUR, and USD. All exclude VAT. Sector premium of
        30 to 50 percent applies to clinical AI, medical devices, critical
        infrastructure, and defence. Other currencies on application.
      </p>
    </div>
  </section>

  <!-- WHAT AGDA IS NOT -->
  <section class="block" id="what-agda-is-not">
    <div class="wrap">
      <h2 class="h2">What AGDA <em>is not.</em></h2>
      <p class="lede muted">
        The four objections that come up in every procurement conversation.
        Narrower is the point.
      </p>

      <ul class="not-list" role="list">
        {notProduct.map((n) => (
          <li>
            <h3 class="h3">{n.h}</h3>
            <p class="body muted">{n.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BENCHMARKS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">The right budget line.</h2>
      <p class="lede muted">
        AGDA is priced against model risk, operational resilience, and AI
        governance programme budgets. Not software procurement. The relevant
        comparisons:
      </p>

      <ul class="benchmarks" role="list">
        {benchmarks.map((b) => (
          <li>
            <h3 class="h3">{b.h}</h3>
            <p class="body muted">{b.p}</p>
          </li>
        ))}
      </ul>

      <p class="body footnote">
        AGDA at £95,000 for a pilot or £180,000 per year for an annual
        subscription sits inside any of those budget lines and produces
        something they cannot: a signed verdict the regulator can verify
        without us.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="block tight">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">
          Nominate a system. <em>One pilot. Four weeks.</em>
        </h2>
        <div class="close-cta reveal">
          <p class="body muted">
            The pilot is sized so a CRO can approve without procurement
            committee escalation. Brief, confidential, no obligation.
          </p>
          <a href="/Intervene/contact/" class="btn">Request a discussion</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 14ch; }
  .hero .lede { margin-top: 32px; max-width: 62ch; }

  .block .h2 { max-width: 22ch; }
  .block .lede { margin-top: 16px; max-width: 60ch; }

  /* ----- Report layers ----- */
  .layers {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 48px;
    border-top: 1px solid var(--ink);
  }
  .layers > li {
    padding: 32px 0;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 10px;
    align-content: start;
  }
  .layer-aud {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 11px;
  }
  .layers p { max-width: 36ch; margin: 4px 0 0; }

  .labs {
    margin-top: 56px;
    padding: 32px;
    background: var(--paper-soft);
    border-left: 2px solid var(--ink);
    max-width: 72ch;
  }
  .labs .h3 { margin: 0 0 12px; }
  .labs p { margin: 0; max-width: 60ch; }

  /* ----- Tiers ----- */
  .tiers {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    gap: 56px;
  }
  .tier {
    padding-top: 40px;
    border-top: 1px solid var(--ink);
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
  }
  .tier-head { display: grid; gap: 8px; align-content: start; }
  .tier-head .h3 { margin: 0; font-size: 28px; }
  .tier-framing {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }

  .formats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .formats > li {
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid var(--hair);
    align-items: baseline;
  }
  .format-label {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
  }
  .format-price {
    text-align: right;
    display: grid;
    gap: 4px;
    justify-items: end;
  }
  .price-gbp {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
  }
  .price-alt {
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tier-includes {
    grid-column: 1 / -1;
    margin: 24px 0 0;
    max-width: 80ch;
  }
  .tier-includes strong { color: var(--ink); font-weight: 500; }
  .tier-triggers {
    grid-column: 1 / -1;
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ----- Rate card ----- */
  .rate-card {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    border-top: 1px solid var(--ink);
  }
  .rate-card > li {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--hair);
    align-items: baseline;
  }
  .rate-label {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
  }
  .rate-price {
    text-align: right;
    display: grid;
    gap: 4px;
    justify-items: end;
  }
  .rate-price .price-gbp { font-size: 15px; }
  .services-head {
    margin: 64px 0 0;
    font-size: 22px;
  }
  .footnote {
    margin: 32px 0 0;
    max-width: 76ch;
    color: var(--muted);
    font-size: 14px;
  }

  /* ----- Not list ----- */
  .not-list {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px 80px;
  }
  .not-list > li { display: grid; gap: 12px; }
  .not-list p { max-width: 44ch; margin: 0; }

  /* ----- Benchmarks ----- */
  .benchmarks {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
  }
  .benchmarks > li { display: grid; gap: 12px; }
  .benchmarks p { max-width: 36ch; margin: 0; }

  /* ----- Close ----- */
  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close-grid .h2 { max-width: 18ch; margin: 0; }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 42ch; }
  .close-cta .btn { justify-self: start; }

  /* ----- Responsive ----- */
  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .layers { grid-template-columns: 1fr; }
    .tier { grid-template-columns: 1fr; gap: 24px; }
    .formats > li { grid-template-columns: 1fr; gap: 4px; }
    .format-price { text-align: left; justify-items: start; }
    .rate-card > li { grid-template-columns: 1fr; gap: 4px; padding: 16px 0; }
    .rate-price { text-align: left; justify-items: start; }
    .not-list { grid-template-columns: 1fr; gap: 48px; }
    .benchmarks { grid-template-columns: 1fr; gap: 40px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
