---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { markAgda } from '../../lib/marks';

const reportLayers = [
  {
    name: 'Executive',
    audience: 'CRO, board, audit committee',
    body: 'Headline verdict, viability status, critical failure summary, regulatory exposure, priority actions. One-page decision frame.',
  },
  {
    name: 'Operational',
    audience: 'Head of Operational Resilience, Head of Model Risk',
    body: 'Plus temporal gating across eight gates with reasons, causal chain with timing, scenario impact, intervention chain, dimension findings.',
  },
  {
    name: 'Specialist',
    audience: 'Intervention readiness owner, regulator liaison',
    body: 'Plus irreversibility profile, failure profiles, single points of failure, framework pressure, regulatory mapping, JSON export, attestation envelope.',
  },
];

const buyerQuestions = [
  {
    audience: 'Executive leadership',
    question: 'Can we proceed with confidence?',
    answer: 'Evidence for deployment, approval and risk-acceptance decisions where assertion is not enough.',
  },
  {
    audience: 'Risk leadership',
    question: 'Can intervention still occur before harm becomes irreversible?',
    answer: 'A measured view of detection, escalation, decision and intervention capability against a reversibility window.',
  },
  {
    audience: 'Board & audit committee',
    question: 'What evidence supports this decision?',
    answer: 'A formal signed, independently verifiable AGDA™ verdict that can be relied on after the decision is made.',
  },
];

const tiers = [
  {
    name: 'Pilot',
    framing: 'Initial evidence for one consequential system.',
    question: 'Can this system be stopped before harm becomes irreversible?',
    for: 'Executive, risk or board teams facing a material deployment, approval, remediation or oversight decision.',
    evidence: 'Formal signed AGDA™ verdict, Failure Exposure Report, regulator bundle, attestation envelope, board evidence readout and intervention scenario support.',
    decision: 'Deployment confidence, risk acceptance, remediation priority, board oversight and regulatory preparation.',
    why: 'Creates a defensible evidence standard before the organisation relies on assertion or expands assessment across more systems.',
    formats: [
      { label: 'Short pilot · 1 system',                   gbp: '£95,000',   eur: '€110,000', usd: '$125,000' },
      { label: 'Structured pilot · 1 system',              gbp: '£120,000',  eur: '€140,000', usd: '$155,000' },
      { label: 'Structured pilot · 2 systems',             gbp: '£175,000',  eur: '€205,000', usd: '$225,000' },
      { label: 'Structured pilot · 3 systems',             gbp: '£225,000',  eur: '€265,000', usd: '$290,000' },
    ],
    includes: 'Failure Exposure Report at all three audience layers, regulator bundle, attestation envelope, Labs Intervention Simulator access, board evidence readout, signed close-out memo.',
  },
  {
    name: 'Annual subscription',
    framing: 'Standing evidence for recurring assurance decisions.',
    question: 'Does Intervention Readiness remain evidenced as systems, dependence and operating conditions change?',
    for: 'Organisations that have completed a pilot and need recurring evidence for material systems.',
    evidence: 'Two assessed systems per year, quarterly re-run rights, engine-hash pinning, updated verdicts and annual board evidence readout.',
    decision: 'Continued deployment, control investment, oversight renewal, risk committee decisions and regulator-facing assurance.',
    why: 'Keeps the answer current as automation becomes more embedded and the cost of delayed intervention increases.',
    formats: [
      { label: 'Annual subscription',     gbp: '£180,000 / yr', eur: '€210,000 / yr', usd: '$235,000 / yr' },
      { label: 'Equivalent quarterly',    gbp: '£45,000 / qtr', eur: '€52,500 / qtr', usd: '$58,750 / qtr' },
    ],
    includes: 'Standing Labs access, two assessed systems per year, engine-hash pinning, quarterly re-run rights on each system, annual board evidence readout.',
  },
  {
    name: 'Enterprise master',
    framing: 'Group-level evidence across systems and entities.',
    question: 'Can a complex organisation evidence intervention capability across the systems that matter most?',
    for: 'Multi-entity groups, regulated portfolios and organisations facing material automation exposure across several operating units.',
    evidence: 'Portfolio-level Intervention Readiness verdicts, regulator-ready bundles, group CRO review, multi-entity reporting and designated AGDA™ operation.',
    decision: 'Group assurance, regulatory engagement, critical deployment governance, resilience investment and board-level risk appetite.',
    why: 'Aligns evidence across entities so the board is not comparing local assertions against group-level exposure.',
    formats: [
      { label: 'Enterprise assurance · custom-scoped',   gbp: '£350,000+ / yr', eur: '€410,000+ / yr', usd: '$450,000+ / yr' },
    ],
    includes: 'Up to 5 assessed systems per year, regulator-liaison support, quarterly portfolio review with group CRO, board evidence readouts, multi-entity invoicing, designated AGDA™ operator.',
    triggers: 'Custom scope applies when assurance spans multiple legal entities, material system portfolios or sustained regulator engagement.',
  },
];

const addons = [
  { label: 'Additional assessed system, post-pilot',                  gbp: '£55,000',       eur: '€65,000',     usd: '$72,000' },
  { label: 'Additional re-run, beyond quarterly included in Annual',   gbp: '£20,000',       eur: '€23,000',     usd: '$25,000' },
  { label: 'Additional named Labs operator',                          gbp: '£3,000 / term', eur: '€3,500 / term', usd: '$4,000 / term' },
  { label: 'Board evidence readout, remote',                           gbp: '£12,000',       eur: '€14,000',     usd: '$15,500' },
  { label: 'Board evidence readout, on-site',                          gbp: '£18,000',       eur: '€21,000',     usd: '$23,000' },
  { label: 'Regulator bundle, post-engine-version change',            gbp: '£6,000',        eur: '€7,000',      usd: '$7,500' },
];

const services = [
  { label: 'Operator enablement, internal assurance team (up to 2 raters)',      gbp: '£55,000',     eur: '€64,000',     usd: '$70,000' },
  { label: 'Operator enablement, external assurance firm',                       gbp: '£85,000',     eur: '€99,000',     usd: '$108,000' },
  { label: 'External assurance firm annual renewal',                             gbp: '£25,000 / yr', eur: '€29,000 / yr', usd: '$32,000 / yr' },
  { label: 'Regulator-liaison support block',                                    gbp: '£18,000',     eur: '€21,000',     usd: '$23,000' },
];

const notProduct = [
  { h: 'Not a governance framework.', p: 'We do not score governance artefact completeness. We measure whether governance can actually intervene when required.' },
  { h: 'Not a compliance solution.',  p: 'Regulatory exposure is an output of the assessment. The category is Intervention Readiness, not clause adherence.' },
  { h: 'Not a risk score.',           p: 'AGDA™ produces a verdict on one question: can you stop it in time? It can inform a risk register. It does not substitute for one.' },
  { h: 'Not a monitoring tool.',      p: 'AGDA™ assesses intervention capability at a point in time. Runtime monitoring is a different product category.' },
];

const benchmarks = [
  { h: 'Board assurance.',                       p: 'Where the question is whether oversight can actually intervene, not whether oversight has been described.' },
  { h: 'Model risk and operational resilience.', p: 'Where the system is material, automated, and capable of creating harm faster than authority can move.' },
  { h: 'Regulatory engagement preparation.',     p: 'Where the organisation needs verifiable evidence of Intervention Readiness, not certification or regulatory approval.' },
];
---

<BaseLayout
  title="Evidence of Intervention Readiness · Intervene"
  description="AGDA™ Intervention Readiness assessments provide signed evidence for consequential decisions: deployment, oversight, risk acceptance, resilience and regulatory scrutiny."
  current="services"
  ogImage="/assets/og/og-services.png"
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <h1 class="h1 reveal">
        Evidence for decisions that cannot rely on assertion.
      </h1>
      <p class="lede muted reveal">
        Organisations routinely invest millions in systems whose failure could
        create significant operational, regulatory or reputational
        consequences. <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> exists to answer whether intervention remains
        possible before those consequences become irreversible.
      </p>
      <div class="hero-cta reveal">
        <a href="/sample-report/" class="btn">View sample verdict</a>
        <a href="/methodology/" class="btn-ghost">How <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> works</a>
      </div>
    </div>
  </section>

  <!-- COMMERCIAL THESIS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">You are not buying activity. <em>You are buying evidence.</em></h2>
      <p class="lede muted">
        The value of an <a href="/intervention-readiness/" class="link">Intervention Readiness</a>
        assessment is determined by the significance of the decision it
        supports: deployment, high-risk system approval, regulatory scrutiny,
        board assurance, operational resilience or executive confidence.
      </p>

      <ul class="buyer-grid reveal" role="list">
        {buyerQuestions.map((b) => (
          <li>
            <span class="mono buyer-audience">{b.audience}</span>
            <h3 class="h3">{b.question}</h3>
            <p class="body muted" set:html={markAgda(b.answer)} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">What every assessment produces.</h2>
      <p class="lede muted">
        A single structured output: an Intervention Readiness Verdict and
        Failure Exposure Report. Three audience layers, all derived from the
        same signed result, engine hash and attestation envelope.
      </p>

      <ul class="layers reveal" role="list">
        {reportLayers.map((l) => (
          <li>
            <h3 class="h3">{l.name}.</h3>
            <span class="mono layer-aud">{l.audience}</span>
            <p class="body muted">{l.body}</p>
          </li>
        ))}
      </ul>

      <div class="labs">
        <h3 class="h3">Intervention decision support.</h3>
        <p class="body muted">
          A what-if console for the resilience function. Test whether proposed
          changes improve intervention timing without re-running the full
          assessment. Included with every tier.
        </p>
      </div>
    </div>
  </section>

  <!-- THREE TIERS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three levels of assurance. <em>Priced by decision significance.</em></h2>
      <p class="lede muted">
        The commercial unit is evidence of Intervention Readiness. Price comes
        after the question answered, the evidence produced, and the decision
        being supported.
      </p>

      <ol class="tiers" role="list">
        {tiers.map((t) => (
          <li class="tier reveal">
            <div class="tier-head">
              <span class="mono tier-label">Assurance level</span>
              <h3 class="h3">{t.name}.</h3>
              <span class="mono tier-framing">{t.framing}</span>
            </div>

            <div class="tier-body">
              <dl class="tier-fields">
                <div>
                  <dt>Question answered</dt>
                  <dd>{t.question}</dd>
                </div>
                <div>
                  <dt>Who it is for</dt>
                  <dd>{t.for}</dd>
                </div>
                <div>
                  <dt>Evidence produced</dt>
                  <dd set:html={markAgda(t.evidence)} />
                </div>
                <div>
                  <dt>Decision supported</dt>
                  <dd>{t.decision}</dd>
                </div>
                <div>
                  <dt>Why it matters</dt>
                  <dd>{t.why}</dd>
                </div>
              </dl>

              <div class="tier-price-block">
                <span class="mono price-heading">Price</span>
                <ul class="formats" role="list">
                  {t.formats.map((f) => (
                    <li>
                      <span class="format-label">{f.label}</span>
                      <span class="format-price">
                        <span class="price-gbp">{f.gbp}</span>
                        <span class="price-alt mono">{f.eur} · {f.usd}</span>
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <p class="body muted tier-includes">
                <strong>Assessment scope.</strong> <span set:html={markAgda(t.includes)} />
              </p>
              {t.triggers && (
                <p class="mono tier-triggers">{t.triggers}</p>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ADD-ONS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Add-ons.</h2>
      <p class="lede muted">
        Additional evidence, re-runs and support when the decision requires
        more coverage. Priced per unit. No volume discount on the first deal in
        a sector.
      </p>

      <ul class="rate-card" role="list">
        {addons.map((a) => (
          <li>
            <span class="rate-label">{a.label}</span>
            <span class="rate-price">
              <span class="price-gbp">{a.gbp}</span>
              <span class="price-alt mono">{a.eur} · {a.usd}</span>
            </span>
          </li>
        ))}
      </ul>

      <h3 class="h3 services-head">Assessment support.</h3>
      <ul class="rate-card" role="list">
        {services.map((a) => (
          <li>
            <span class="rate-label">{a.label}</span>
            <span class="rate-price">
              <span class="price-gbp">{a.gbp}</span>
              <span class="price-alt mono">{a.eur} · {a.usd}</span>
            </span>
          </li>
        ))}
      </ul>

      <p class="body muted footnote">
        Prices shown in GBP, EUR, and USD. All exclude VAT. Sector premium of
        30 to 50 percent applies to clinical AI, medical devices, critical
        infrastructure, and defence. Other currencies on application.
      </p>
    </div>
  </section>

  <!-- WHAT AGDA™ IS NOT -->
  <section class="block" id="what-agda-is-not">
    <div class="wrap">
      <h2 class="h2">What <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> <em>is not.</em></h2>
      <p class="lede muted">
        The category boundary matters. <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> measures Intervention
        Readiness. It does not sell governance theatre under another name.
      </p>

      <ul class="not-list" role="list">
        {notProduct.map((n) => (
          <li>
            <h3 class="h3">{n.h}</h3>
            <p class="body muted" set:html={markAgda(n.p)} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BENCHMARKS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Where the assessment belongs.</h2>
      <p class="lede muted">
        <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> is priced against board assurance, model risk and
        operational resilience budgets. Not software procurement.
      </p>

      <ul class="benchmarks" role="list">
        {benchmarks.map((b) => (
          <li>
            <h3 class="h3">{b.h}</h3>
            <p class="body muted">{b.p}</p>
          </li>
        ))}
      </ul>

      <p class="body footnote">
        <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> at £95,000 for a pilot or £180,000 per year for an annual
        subscription turns that budget into a formal signed verdict on one
        question: can the organisation intervene before harm becomes
        irreversible?
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="block tight">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">
          Nominate a system. <em>Measure whether it can be stopped in time.</em>
        </h2>
        <div class="close-cta reveal">
          <p class="body muted">
            The pilot is sized around one consequential system and one
            Intervention Readiness question. Review the sample verdict first if
            you want to see the evidence standard.
          </p>
          <div class="cta-row">
            <a href="/sample-report/" class="btn">View sample verdict</a>
            <a href="/contact/" class="btn-ghost">Book a conversation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 22ch; }
  .hero .lede { margin-top: 32px; max-width: 62ch; }
  .hero-cta { margin-top: 48px; display: flex; gap: 16px; flex-wrap: wrap; }

  .block .h2 { max-width: 28ch; }
  .block .lede { margin-top: 16px; max-width: 60ch; }

  /* ----- Buyer questions ----- */
  .buyer-grid {
    list-style: none;
    margin: 72px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    border-top: 1px solid var(--hair-strong);
  }
  .buyer-grid > li {
    padding-top: 32px;
    display: grid;
    gap: 12px;
    align-content: start;
  }
  .buyer-audience {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .buyer-grid .h3 { margin: 0; }
  .buyer-grid p { margin: 0; max-width: 34ch; }

  /* ----- Report layers ----- */
  .layers {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 48px;
    border-top: 1px solid var(--hair-strong);
  }
  .layers > li {
    padding: 32px 0;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 10px;
    align-content: start;
  }
  .layer-aud {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 11px;
  }
  .layers p { max-width: 36ch; margin: 4px 0 0; }

  .labs {
    margin-top: 56px;
    padding: 32px;
    background: var(--paper-soft);
    border-left: 2px solid var(--accent);
    max-width: 72ch;
  }
  .labs .h3 { margin: 0 0 12px; }
  .labs p { margin: 0; max-width: 60ch; }

  /* ----- Tiers ----- */
  .tiers {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    gap: 56px;
  }
  .tier {
    padding-top: 40px;
    border-top: 1px solid var(--hair-strong);
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
  }
  .tier-head { display: grid; gap: 8px; align-content: start; }
  .tier-head .h3 { margin: 0; font-size: 28px; }
  .tier-label,
  .tier-framing {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .tier-body {
    display: grid;
    gap: 28px;
    min-width: 0;
  }
  .tier-fields {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 40px;
    border-top: 1px solid var(--hair);
  }
  .tier-fields > div {
    padding: 20px 0;
    border-bottom: 1px solid var(--hair);
  }
  .tier-fields > div:last-child {
    grid-column: 1 / -1;
  }
  .tier-fields dt {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tier-fields dd {
    margin: 8px 0 0;
    max-width: 48ch;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.58;
    color: var(--ink);
  }
  .tier-fields > div:last-child dd {
    max-width: 68ch;
    color: var(--muted);
  }
  .tier-price-block {
    display: grid;
    gap: 12px;
  }
  .price-heading {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }

  .formats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--hair-strong);
  }
  .formats > li {
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid var(--hair);
    align-items: baseline;
  }
  .format-label {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
  }
  .format-price {
    text-align: right;
    display: grid;
    gap: 4px;
    justify-items: end;
  }
  .price-gbp {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
  }
  .price-alt {
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tier-includes {
    margin: 0;
    max-width: 80ch;
  }
  .tier-includes strong { color: var(--ink); font-weight: 500; }
  .tier-triggers {
    margin: 0;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ----- Rate card ----- */
  .rate-card {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    border-top: 1px solid var(--hair-strong);
  }
  .rate-card > li {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--hair);
    align-items: baseline;
  }
  .rate-label {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
  }
  .rate-price {
    text-align: right;
    display: grid;
    gap: 4px;
    justify-items: end;
  }
  .rate-price .price-gbp { font-size: 15px; }
  .services-head {
    margin: 64px 0 0;
    font-size: 22px;
  }
  .footnote {
    margin: 32px 0 0;
    max-width: 76ch;
    color: var(--muted);
    font-size: 14px;
  }

  /* ----- Not list ----- */
  .not-list {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px 80px;
  }
  .not-list > li { display: grid; gap: 12px; }
  .not-list p { max-width: 44ch; margin: 0; }

  /* ----- Benchmarks ----- */
  .benchmarks {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
  }
  .benchmarks > li { display: grid; gap: 12px; }
  .benchmarks p { max-width: 36ch; margin: 0; }

  /* ----- Close ----- */
  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close-grid .h2 { max-width: 24ch; margin: 0; }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 42ch; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
  .close-cta .btn { justify-self: start; }

  /* ----- Responsive ----- */
  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .buyer-grid { grid-template-columns: 1fr; gap: 40px; }
    .layers { grid-template-columns: 1fr; }
    .tier { grid-template-columns: 1fr; gap: 24px; }
    .tier-fields { grid-template-columns: 1fr; }
    .tier-fields > div:last-child { grid-column: auto; }
    .formats > li { grid-template-columns: 1fr; gap: 4px; }
    .format-price { text-align: left; justify-items: start; }
    .rate-card > li { grid-template-columns: 1fr; gap: 4px; padding: 16px 0; }
    .rate-price { text-align: left; justify-items: start; }
    .not-list { grid-template-columns: 1fr; gap: 48px; }
    .benchmarks { grid-template-columns: 1fr; gap: 40px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
