---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChainFlow from '../components/ChainFlow.astro';
import VerdictSeal from '../components/VerdictSeal.astro';
import SectorCard from '../components/SectorCard.astro';
import InsightCard from '../components/InsightCard.astro';

const sectors = [
  {
    name: 'UK regulated finance',
    pressure: 'PRA · FCA · SS1/23 · SMF',
    consequence: 'A named accountable executive without the authority to halt the model in time. Accountability on paper, exposure in production.',
    href: '/Intervene/sectors/#uk-finance',
  },
  {
    name: 'EU high-risk AI',
    pressure: 'EU AI Act · human oversight',
    consequence: 'Article 14 oversight that cannot alter the outcome before it lands is documentation, not control.',
    href: '/Intervene/sectors/#eu-ai',
  },
  {
    name: 'Critical national infrastructure',
    pressure: 'NIS · operational resilience',
    consequence: 'Automated systems acting faster than the escalation chain that is meant to govern them.',
    href: '/Intervene/sectors/#cni',
  },
  {
    name: 'Public services',
    pressure: 'Accountability · public law',
    consequence: 'Decisions at population scale, with a redress path slower than the harm it is meant to contain.',
    href: '/Intervene/sectors/#public',
  },
];

const insights = [
  {
    kicker: 'Note',
    title: 'Accountability theatre: the named SMF without halt authority',
    dek: 'A designated executive who cannot stop the system is a name on a chart, not a control. AGDA penalises the pairing.',
    href: '/Intervene/insights/accountability-theatre/',
  },
  {
    kicker: 'Note',
    title: 'Coincidence is not a margin',
    dek: 'An absence of incidents is evidence of untested exposure, not effective control. Quiet is not the same as safe.',
    href: '/Intervene/insights/coincidence-is-not-a-margin/',
  },
  {
    kicker: 'Note',
    title: 'The 36-hour window, and why the board hears last',
    dek: 'Authority travels upward through people who cannot act. By the time it reaches the board, the cheap intervention has passed.',
    href: '/Intervene/insights/the-thirty-six-hour-window/',
  },
];
---

<BaseLayout
  title="Intervene · The independent authority on intervention readiness"
  description="If your most consequential system fails right now, can you stop it in time? Intervene assesses whether your organisation can intervene before harm becomes irreversible, and signs the answer."
  current="home"
>
  <!-- 1 · Hero: the question, dominant -->
  <section class="hero">
    <div class="wrap">
      <h1 class="display-xl">Can you stop it <em>in time?</em></h1>
      <p class="hero-position">Intervene is the independent authority on intervention readiness.</p>
      <div class="hero-cta">
        <a href="/Intervene/contact/" class="btn">Request a confidential discussion</a>
        <a href="/Intervene/agda/" class="btn-ghost">How AGDA works</a>
      </div>
      <p class="hero-support body muted">
        We assess whether your organisation can intervene before harm becomes
        irreversible, and we sign the answer.
      </p>
    </div>
  </section>

  <!-- 2 · The reframe: one line -->
  <section class="block reframe">
    <div class="wrap">
      <span class="label">Intervention readiness</span>
      <h2 class="h2">
        Your framework says you are in control. <em>A live failure is the only
        other way to find out.</em>
      </h2>
      <a href="/Intervene/agda/" class="link reframe-link">What intervention readiness means</a>
    </div>
  </section>

  <!-- 3 · The window: consequence -->
  <section class="block">
    <div class="wrap">
      <div class="window-head">
        <h2 class="h2">By the time the board is told, <em>the window has closed.</em></h2>
        <p class="lede muted">
          A board that cannot intervene is not a safeguard. It is a witness.
        </p>
      </div>

      <ol class="window-grid reveal" role="list">
        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+0</span>
            <span class="stage-label">System event</span>
          </div>
          <h3 class="h3">Detection latent.</h3>
          <p class="body muted">
            An AI-driven decision produces outputs outside expected parameters.
            The system runs on. No one with authority to act has been told.
          </p>
          <span class="status mono">Intervention possible</span>
        </li>

        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+6h</span>
            <span class="stage-label">Operations</span>
          </div>
          <h3 class="h3">Authority absent.</h3>
          <p class="body muted">
            Deviation noticed, damage accumulating. The first person in the
            chain lacks the authority to halt the system. The route up is
            unclear.
          </p>
          <span class="status mono">Intervention possible</span>
        </li>

        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+18h</span>
            <span class="stage-label">Management</span>
          </div>
          <h3 class="h3">Window closing.</h3>
          <p class="body muted">
            Still running, cost compounding by the hour. Received at management
            level. Authority to act still uncertain.
          </p>
          <span class="status mono">Window closing</span>
        </li>

        <li class="stage critical">
          <div class="chip-row">
            <span class="time-chip warn">T+36h</span>
            <span class="stage-label">Board</span>
          </div>
          <h3 class="h3">Witness, not safeguard.</h3>
          <p class="body muted">
            Uncontainable. Regulatory exposure, reputational damage. The board
            is informed. The window has already closed.
          </p>
          <span class="status mono warn">Window closed</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- 4 · AGDA: the signed verdict -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Capability against evidence. <em>Every verdict signed.</em></h2>
      <p class="lede muted">
        Same inputs, same outputs, bound to a locked engine hash. A regulator
        can verify the verdict without contacting us.
      </p>

      <ChainFlow />

      <div class="agda-foot">
        <VerdictSeal verdict="Signed verdict" meta="Ed25519 · locked engine hash" />
        <div class="agda-links">
          <a href="/Intervene/agda/" class="link">What AGDA delivers</a>
          <a href="/Intervene/sample-report/" class="link">See a sample report</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 · Sectors -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Built for your <em>regulatory reality.</em></h2>
      <div class="card-grid sectors-grid reveal" role="list">
        {sectors.map((s) => (
          <SectorCard name={s.name} pressure={s.pressure} consequence={s.consequence} href={s.href} />
        ))}
      </div>
      <a href="/Intervene/sectors/" class="link sectors-link">All sectors</a>
    </div>
  </section>

  <!-- 6 · Authority and independence -->
  <section class="block" id="founder">
    <div class="wrap-narrow">
      <span class="label founder-label">The practice</span>
      <h2 class="h2">James Saint.</h2>
      <p class="body">
        Three decades across technology, systems architecture, payments and
        operational risk. James founded AGDA™ to answer the question
        traditional governance frameworks leave open.
      </p>
      <p class="founder-q">
        Can an organisation actually intervene before harm becomes irreversible?
      </p>
      <ul class="commitments" role="list">
        <li>Independent. No platform to sell you into, no managed-service lock-in.</li>
        <li>Evidence over intention. The verdict follows what is demonstrated, not what is claimed.</li>
        <li>Signed and verifiable. You do not have to take our word for the answer.</li>
        <li>Honest about fit. If AGDA is not the right instrument for you, we say so.</li>
      </ul>
      <a href="/Intervene/about/" class="link">About the practice</a>
    </div>
  </section>

  <!-- 7 · Insights -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">A published <em>point of view.</em></h2>
      <div class="insights-list reveal" role="list">
        {insights.map((a) => (
          <InsightCard title={a.title} dek={a.dek} href={a.href} kicker={a.kicker} />
        ))}
      </div>
      <a href="/Intervene/insights/" class="link insights-link">All insights</a>
    </div>
  </section>

  <!-- 8 · Close -->
  <section class="block close">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">
          Could your organisation stop its most consequential system <em>right now?</em>
        </h2>
        <div class="close-cta reveal">
          <p class="body muted">
            If you are not certain, that is worth a conversation. Brief,
            confidential, no obligation.
          </p>
          <a href="/Intervene/contact/" class="btn">Request a confidential discussion</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* 1 · Hero. Black masthead: maximum contrast, set against the white
     header above and the white reframe section below. */
  .hero {
    background: var(--ink);
    color: var(--paper);
    padding-top: clamp(96px, 14vh, 184px);
    padding-bottom: clamp(80px, 11vh, 152px);
    border-bottom: 0;
  }
  .hero .display-xl { max-width: 14ch; color: var(--paper); }
  .hero-position {
    margin: clamp(32px, 5vh, 56px) 0 0;
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.6vw, 24px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--paper);
    max-width: 32ch;
  }
  .hero-cta {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-support {
    margin-top: 40px;
    max-width: 46ch;
    color: rgba(255, 255, 255, 0.66);
  }

  /* Buttons inverted for the black hero. */
  .hero .btn {
    background: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
  }
  .hero .btn:hover { background: var(--paper-mid); border-color: var(--paper-mid); }
  .hero .btn-ghost {
    background: transparent;
    color: var(--paper);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .hero .btn-ghost:hover { border-color: var(--paper); }
  .hero ::selection { background: var(--paper); color: var(--ink); }

  .block .h2 { max-width: 22ch; }
  .block > .wrap > .lede { margin-top: 16px; max-width: 50ch; }

  /* 2 · Reframe */
  .reframe .label {
    padding-bottom: 16px;
    border-bottom: 1px solid var(--hair);
    margin-bottom: 32px;
  }
  .reframe .h2 { max-width: 24ch; font-size: clamp(34px, 4.4vw, 60px); }
  .reframe-link { display: inline-block; margin-top: 40px; font-size: 15px; }

  /* 3 · Window timeline */
  .window-head { margin-bottom: 80px; }
  .window-head .h2 { max-width: 20ch; }
  .window-head .lede { margin-top: 20px; max-width: 44ch; }

  .window-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 32px;
    border-top: 1px solid var(--ink);
  }
  .window-grid > .stage {
    padding: 32px 0;
    display: grid;
    gap: 16px;
    align-content: start;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 480ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .window-grid.in > .stage { opacity: 1; transform: none; }
  .window-grid.in > .stage:nth-child(1) { transition-delay: 0ms; }
  .window-grid.in > .stage:nth-child(2) { transition-delay: 140ms; }
  .window-grid.in > .stage:nth-child(3) { transition-delay: 280ms; }
  .window-grid.in > .stage:nth-child(4) { transition-delay: 420ms; }

  .chip-row { display: flex; align-items: center; gap: 12px; }
  .time-chip {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 9px;
    line-height: 1;
  }
  .time-chip.warn { background: var(--warn); }
  .stage-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .window-grid .h3 { font-size: 22px; margin: 4px 0 0; }
  .window-grid p { max-width: 32ch; margin: 0; }
  .status {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--hair);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .status.warn { color: var(--warn); }

  @media (prefers-reduced-motion: reduce) {
    .window-grid > .stage { opacity: 1; transform: none; transition: none; }
  }

  /* 4 · AGDA signed verdict */
  .agda-foot {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--hair);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .agda-links { display: flex; gap: 32px; flex-wrap: wrap; }

  /* 5 · Sectors */
  .sectors-grid { margin-top: 56px; grid-template-columns: repeat(2, 1fr); }
  .sectors-link, .insights-link { display: inline-block; margin-top: 40px; font-size: 15px; }

  /* 6 · Founder */
  #founder .label.founder-label {
    padding-bottom: 16px;
    border-bottom: 1px solid var(--hair);
    margin-bottom: 24px;
  }
  #founder .h2 { max-width: 24ch; margin: 0 0 24px; }
  #founder .body { max-width: 60ch; margin: 0 0 16px; }
  .founder-q {
    font-family: var(--font-sans);
    font-size: 22px;
    font-style: italic;
    color: var(--ink);
    max-width: 42ch;
    margin: 24px 0;
    padding-left: 20px;
    border-left: 2px solid var(--ink);
  }
  .commitments {
    list-style: none;
    margin: 32px 0;
    padding: 0;
    border-top: 1px solid var(--hair);
  }
  .commitments > li {
    padding: 16px 0;
    border-bottom: 1px solid var(--hair);
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink);
    max-width: 56ch;
  }

  /* 7 · Insights */
  .insights-list { margin-top: 56px; }

  /* 8 · Close */
  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close .h2 { max-width: 18ch; margin: 0; }
  .close-cta { display: grid; gap: 24px; align-content: start; padding-top: 12px; }
  .close-cta .body { margin: 0; max-width: 38ch; }
  .close-cta .btn { justify-self: start; }

  @media (max-width: 880px) {
    .sectors-grid { grid-template-columns: 1fr; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
    .window-grid { grid-template-columns: 1fr 1fr; column-gap: 24px; }
    .agda-foot { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 560px) {
    .window-grid { grid-template-columns: 1fr; }
  }
</style>
