---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChainFlow from '../components/ChainFlow.astro';

const tiers = [
  {
    name: 'Pilot',
    framing: 'First engagement. One system.',
    blurb: 'Four-week or 90-day. Signed Failure Exposure Report at three audience layers, regulator bundle, attestation envelope.',
    price: 'From £95,000',
  },
  {
    name: 'Annual',
    framing: 'Post-pilot. Standing.',
    blurb: 'Five operator seats, two assessed systems per year, quarterly re-run rights, engine-hash pinning, annual board readout.',
    price: '£180,000 / yr',
  },
  {
    name: 'Enterprise',
    framing: 'Multi-system, multi-entity. Custom-scoped.',
    blurb: 'Up to 15 seats, 5 systems per year, regulator-liaison hours, quarterly portfolio review with group CRO, designated operator.',
    price: 'From £350,000 / yr',
  },
];
---

<BaseLayout
  title="Intervene · Independent Advisory"
  description="Independent advisory for boards. We test whether your organisation can detect, escalate, decide, and intervene before failure becomes irreversible."
  current="home"
>
  <section class="hero">
    <div class="wrap">
      <div class="hero-rotator" data-hero-rotator aria-live="polite">
        <article class="slide is-active" data-slide aria-hidden="false">
          <h1 class="h1">
            If your AI system goes wrong right now. <em>Can you stop it?</em>
          </h1>
          <p class="lede slide-lede">
            AGDA™ gives you a deterministic, signed answer. Bound to a locked
            engine version. An audit committee can defend it. A regulator can
            verify it without contacting us.
          </p>
        </article>
        <article class="slide" data-slide aria-hidden="true">
          <h1 class="h1">
            Evidence over intention. <em>Every verdict signed.</em>
          </h1>
          <p class="lede slide-lede">
            Most AI governance tests whether controls exist. AGDA tests whether
            they work in time. Same inputs, same output, every time, bound to a
            locked engine hash.
          </p>
        </article>
        <article class="slide" data-slide aria-hidden="true">
          <h1 class="h1">
            A safeguard. Or <em>a witness.</em>
          </h1>
          <p class="lede slide-lede">
            By the time the board is told, the window has closed. We measure
            whether the chain holds before it has to.
          </p>
        </article>
      </div>

      <div class="hero-cta reveal">
        <a href="/Intervene/contact/" class="btn">Request a discussion</a>
        <a href="/Intervene/method/" class="btn-ghost">Our method</a>
      </div>
    </div>
  </section>

  <script>
    import { initHeroRotator } from '../lib/hero-rotator.ts';
    initHeroRotator();
  </script>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">The chain that decides whether you can intervene.</h2>
      <ChainFlow />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="window-head">
        <span class="window-kicker mono">The SEDI chain meets the authority chain</span>
        <h2 class="h2">By the time the board is told, <em>the window has closed.</em></h2>
        <p class="lede muted">
          The crisis begins the moment a system fails. Authority to stop it
          travels upward through people who cannot act. By the time it
          reaches the board, the moment for low-cost intervention has passed.
          The SEDI chain fails when authority moves slower than the harm
          window.
        </p>
      </div>

      <ol class="window-grid reveal" role="list">
        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+0</span>
            <span class="stage-label">System event</span>
          </div>
          <h3 class="h3">Detection latent.</h3>
          <p class="body muted">
            An AI-driven decision produces outputs outside expected
            parameters. The system runs on. No signal has reached executive
            level. No one with authority to act has been told.
          </p>
          <span class="status mono">Intervention possible</span>
        </li>

        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+6h</span>
            <span class="stage-label">Operations</span>
          </div>
          <h3 class="h3">Authority absent.</h3>
          <p class="body muted">
            Deviation noticed. Damage accumulating. Signal reaches operations,
            but the first person in the chain lacks authority to halt the
            system. Escalation route unclear.
          </p>
          <span class="status mono">Intervention possible</span>
        </li>

        <li class="stage">
          <div class="chip-row">
            <span class="time-chip">T+18h</span>
            <span class="stage-label">Management</span>
          </div>
          <h3 class="h3">Window closing.</h3>
          <p class="body muted">
            Still running. Cost compounding with every hour. Issue received at
            management level. Authority to act uncertain. Escalation continues
            upward.
          </p>
          <span class="status mono">Window closing</span>
        </li>

        <li class="stage critical">
          <div class="chip-row">
            <span class="time-chip warn">T+36h</span>
            <span class="stage-label">Board</span>
          </div>
          <h3 class="h3">Witness, not safeguard.</h3>
          <p class="body muted">
            Uncontainable. Regulatory exposure. Reputational damage. The board
            is informed. The intervention window has already closed. They are
            not a safeguard. They are a witness.
          </p>
          <span class="status mono warn">Window closed</span>
        </li>
      </ol>
    </div>
  </section>

  <section class="block" id="who-we-work-with">
    <div class="wrap">
      <h2 class="h2">Who we <em>work with.</em></h2>
      <p class="lede muted">
        Intervene works with organisations where AI, operational systems or
        model risk failures could create regulatory, financial, safety or
        reputational consequences.
      </p>
      <span class="group-label mono">Typical engagement contexts</span>
      <ul class="audience" role="list">
        <li>AI governance programmes</li>
        <li>Model risk functions</li>
        <li>Operational resilience programmes</li>
        <li>Internal audit reviews</li>
        <li>Board and risk committee assurance</li>
        <li>High-consequence decision systems</li>
        <li>Regulated financial services</li>
        <li>Public sector and critical services</li>
      </ul>
    </div>
  </section>

  <section class="block" id="pilot">
    <div class="wrap">
      <div class="pilot-head">
        <span class="window-kicker mono">Current status</span>
        <h2 class="h2">
          AGDA™ is being introduced through <em>selected paid pilot
          engagements.</em>
        </h2>
        <p class="lede muted">
          A pilot is not a trial login or a casual review of the software. It
          is a structured intervention-readiness assessment delivered with
          executive-level outputs.
        </p>
      </div>

      <div class="pilot-body reveal">
        <div class="pilot-receive">
          <span class="group-label mono">Pilot participants receive</span>
          <ul class="receive-list" role="list">
            <li>Full AGDA™ assessment</li>
            <li>Deterministic intervention-readiness verdict</li>
            <li>Board-ready report</li>
            <li>Executive review workshop</li>
            <li>Methodology feedback session</li>
            <li>Clear view of where the intervention chain holds and where it breaks</li>
          </ul>
        </div>

        <div class="pilot-purpose">
          <p class="body">
            The purpose of the pilot is to put a defensible answer in writing
            before a critical event, regulatory review or board-level
            challenge forces the question.
          </p>
          <a href="/Intervene/contact/" class="btn">Discuss a paid pilot</a>
        </div>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three tiers. <em>Priced per assessment.</em></h2>
      <p class="lede muted">
        The commercial unit is the assessment, not the seat. Customers expand
        by assessing more systems, not by adding users.
      </p>

      <ul class="tiers-preview reveal" role="list">
        {tiers.map((t) => (
          <li>
            <h3 class="h3">{t.name}.</h3>
            <span class="mono tier-framing">{t.framing}</span>
            <p class="body muted">{t.blurb}</p>
            <span class="mono tier-price">{t.price}</span>
          </li>
        ))}
      </ul>

      <a href="/Intervene/services/" class="services-link">See all tiers, add-ons, and rate card <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="block" id="founder">
    <div class="wrap-narrow">
      <span class="window-kicker mono">About the founder</span>
      <h2 class="h2">James Saint.</h2>
      <p class="body">
        Intervene was founded by James Saint, a technology founder and former
        co-founder of the Institute of Financial Innovation in Transactions and
        Security.
      </p>
      <p class="body muted">
        After three decades working across technology, systems architecture,
        payments, digital products and operational risk, James developed AGDA™
        to answer a question traditional governance frameworks leave
        unresolved:
      </p>
      <p class="founder-q">
        Can an organisation actually intervene before harm becomes irreversible?
      </p>
      <p class="body muted">
        James works at the point where governance, technology, operational risk
        and intervention capability meet.
      </p>
    </div>
  </section>

  <section class="block" id="company">
    <div class="wrap-narrow">
      <span class="window-kicker mono">Intervene Limited</span>
      <h2 class="h2">Owner and developer of <em>AGDA™.</em></h2>
      <p class="body">
        Intervene Limited is the owner and developer of AGDA™, a deterministic
        intervention-readiness assessment methodology and platform.
      </p>
      <p class="body muted">
        AGDA™ evaluates whether an organisation can detect, escalate, decide and
        intervene before critical failures become irreversible.
      </p>
      <p class="body muted">
        The methodology, software, reporting structure and signed verdict are
        designed to support board, audit, risk and regulatory conversations
        where evidence matters.
      </p>
      <dl class="company-meta">
        <div><dt>Registered</dt><dd>England and Wales</dd></div>
      </dl>
    </div>
  </section>

  <section class="block close">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">
          Could your organisation stop its most consequential system <em>right now?</em>
        </h2>
        <div class="close-cta reveal">
          <p class="body muted">
            If not certain, that is worth a conversation. Brief, confidential,
            no obligation.
          </p>
          <a href="/Intervene/contact/" class="btn">Request a discussion</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 160px;
    border-bottom: 1px solid var(--hair);
  }

  /* Rotator: both slides occupy the same grid cell, container takes the
     taller of the two so there is no layout shift between transitions. */
  .hero-rotator {
    display: grid;
    grid-template-areas: 'slide';
  }
  .slide {
    grid-area: slide;
    opacity: 0;
    transition: opacity 500ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .slide .h1 { max-width: 16ch; margin: 0; }
  .slide-lede {
    margin-top: 56px;
    max-width: 50ch;
    color: var(--ink);
  }

  .hero-cta {
    margin-top: 80px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
  }

  .block .h2 { max-width: 22ch; }
  .block > .wrap > .lede { margin-top: 16px; max-width: 50ch; }

  /* Window timeline (T+0 to T+36h) */
  .window-head {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 80px;
    align-items: start;
    margin-bottom: 80px;
  }
  .window-head .h2 { max-width: 18ch; margin: 8px 0 0; }
  .window-head .lede { max-width: 48ch; margin: 0; padding-top: 8px; }
  .window-kicker {
    grid-column: 1 / -1;
    display: block;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--hair);
    margin-bottom: 32px;
  }

  .window-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 32px;
    border-top: 1px solid var(--ink);
  }
  .window-grid > .stage {
    padding: 32px 0 32px;
    display: grid;
    gap: 16px;
    align-content: start;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 480ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .window-grid.in > .stage { opacity: 1; transform: none; }
  .window-grid.in > .stage:nth-child(1) { transition-delay: 0ms; }
  .window-grid.in > .stage:nth-child(2) { transition-delay: 140ms; }
  .window-grid.in > .stage:nth-child(3) { transition-delay: 280ms; }
  .window-grid.in > .stage:nth-child(4) { transition-delay: 420ms; }

  .chip-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .time-chip {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 9px;
    line-height: 1;
  }
  .time-chip.warn { background: var(--warn); }
  .stage-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .window-grid .h3 { font-size: 22px; margin: 4px 0 0; }
  .window-grid p { max-width: 32ch; margin: 0; }
  .status {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--hair);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .status.warn { color: var(--warn); }

  @media (prefers-reduced-motion: reduce) {
    .window-grid > .stage {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Three-tier preview */
  .tiers-preview {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 48px;
    border-top: 1px solid var(--ink);
    /* override .reveal so children stagger individually */
    opacity: 1;
    transform: none;
  }
  .tiers-preview > li {
    padding: 32px 0 32px;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 12px;
    align-content: start;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 480ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tiers-preview.in > li { opacity: 1; transform: none; }
  .tiers-preview.in > li:nth-child(1) { transition-delay: 0ms; }
  .tiers-preview.in > li:nth-child(2) { transition-delay: 140ms; }
  .tiers-preview.in > li:nth-child(3) { transition-delay: 280ms; }

  .tiers-preview .h3 { margin: 0; font-size: 28px; }
  .tier-framing {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }
  .tiers-preview p { max-width: 32ch; margin: 4px 0 0; }
  .tier-price {
    margin-top: 8px;
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .services-link {
    display: inline-block;
    margin-top: 48px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid var(--hair-strong);
    padding-bottom: 2px;
    transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .services-link:hover { border-color: var(--ink); }

  /* Shared section label */
  .group-label {
    display: block;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--hair);
  }

  /* Who we work with */
  #who-we-work-with .group-label { margin-top: 48px; }
  .audience {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 64px;
    border-top: 1px solid var(--ink);
  }
  .audience > li {
    padding: 18px 0;
    border-bottom: 1px solid var(--hair);
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink);
  }

  /* Pilot engagements */
  .pilot-head .h2 { max-width: 22ch; margin: 8px 0 0; }
  .pilot-head .lede { max-width: 52ch; margin-top: 16px; }
  .pilot-body {
    margin-top: 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .receive-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--hair);
  }
  .receive-list > li {
    padding: 16px 0;
    border-bottom: 1px solid var(--hair);
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink);
    max-width: 36ch;
  }
  .pilot-purpose {
    display: grid;
    gap: 32px;
    align-content: start;
  }
  .pilot-purpose .body { margin: 0; max-width: 40ch; }
  .pilot-purpose .btn { justify-self: start; }

  /* Founder note + company */
  #founder .h2, #company .h2 { max-width: 24ch; margin: 12px 0 24px; }
  #founder .body, #company .body { max-width: 62ch; margin: 0 0 16px; }
  .founder-q {
    font-family: var(--font-sans);
    font-size: 22px;
    font-style: italic;
    color: var(--ink);
    max-width: 42ch;
    margin: 24px 0;
    padding-left: 20px;
    border-left: 2px solid var(--ink);
  }
  .company-meta {
    margin: 32px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    display: grid;
    gap: 16px;
  }
  .company-meta > div {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .company-meta dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .company-meta dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink);
  }

  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close .h2 {
    max-width: 18ch;
    margin: 0;
  }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 38ch; }
  .close-cta .btn { justify-self: start; }

  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .slide-lede { margin-top: 40px; }
    .hero-cta { margin-top: 56px; }
    .tiers-preview { grid-template-columns: 1fr; column-gap: 0; }
    .audience { grid-template-columns: 1fr; column-gap: 0; }
    .pilot-body { grid-template-columns: 1fr; gap: 48px; }
    .company-meta > div { grid-template-columns: 1fr; gap: 4px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
    .window-head {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 48px;
    }
    .window-grid { grid-template-columns: 1fr 1fr; column-gap: 24px; }
  }
  @media (max-width: 560px) {
    .window-grid { grid-template-columns: 1fr; }
  }
</style>
