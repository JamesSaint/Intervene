---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChainFlow from '../components/ChainFlow.astro';
import ScopeBar from '../components/ScopeBar.astro';
---

<BaseLayout
  title="Intervene · Independent Advisory"
  description="Independent advisory for boards. We test whether your organisation can detect, escalate, decide, and intervene before failure becomes irreversible."
  current="home"
  noindex={true}
>
  <section class="hero">
    <div class="wrap">
      <div class="hero-rotator" data-hero-rotator aria-live="polite">
        <article class="slide is-active" data-slide aria-hidden="false">
          <h1 class="h1">
            Move first. Or be moved <em>by what you missed.</em>
          </h1>
          <p class="lede slide-lede">
            Independent advisory. We test whether your governance translates
            to operational control, before a live failure answers the
            question for you.
          </p>
        </article>
        <article class="slide" data-slide aria-hidden="true">
          <h1 class="h1">
            Intervention, on evidence. <em>Not intention.</em>
          </h1>
          <p class="lede slide-lede">
            AGDA scores intervention capability against evidence. Every
            verdict is cryptographically signed. The regulator can verify
            without us.
          </p>
        </article>
        <article class="slide" data-slide aria-hidden="true">
          <h1 class="h1">
            A safeguard. Or <em>a witness.</em>
          </h1>
          <p class="lede slide-lede">
            By the time the board is told, the window has closed. We measure
            whether the chain holds before it has to.
          </p>
        </article>
      </div>

      <div class="hero-cta reveal">
        <a href="/contact/" class="btn">Request a discussion</a>
        <a href="/method/" class="btn-ghost">Our method</a>
      </div>
    </div>
  </section>

  <script>
    import { initHeroRotator } from '../lib/hero-rotator.ts';
    initHeroRotator();
  </script>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">The chain that decides whether you can intervene.</h2>
      <ChainFlow />
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three services. <em>One question.</em></h2>
      <p class="lede muted">
        Can the people responsible for your most consequential systems
        actually stop them when they need to?
      </p>

      <ul class="services" role="list">
        <li class="reveal">
          <ScopeBar pattern="focused" duration="Point-in-time · 2–3 weeks" />
          <h3 class="h3">Exposure assessment.</h3>
          <p class="body muted">One system, one scenario. A clear view of where intervention breaks down.</p>
        </li>
        <li class="reveal">
          <ScopeBar pattern="recurring" duration="Episodic · per decision" />
          <h3 class="h3">Board-level advisory.</h3>
          <p class="body muted">Independent judgement where internal certainty may be misleading.</p>
        </li>
        <li class="reveal">
          <ScopeBar pattern="continuous" duration="Continuous · retainer" />
          <h3 class="h3">Integrity oversight.</h3>
          <p class="body muted">Continued visibility across consequential systems as exposure evolves.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="block close">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">
          Could your organisation stop its most consequential system <em>right now?</em>
        </h2>
        <div class="close-cta reveal">
          <p class="body muted">
            If not certain, that is worth a conversation. Brief, confidential,
            no obligation.
          </p>
          <a href="/contact/" class="btn">Request a discussion</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 160px;
    border-bottom: 1px solid var(--hair);
  }

  /* Rotator: both slides occupy the same grid cell, container takes the
     taller of the two so there is no layout shift between transitions. */
  .hero-rotator {
    display: grid;
    grid-template-areas: 'slide';
  }
  .slide {
    grid-area: slide;
    opacity: 0;
    transition: opacity 800ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .slide .h1 { max-width: 16ch; margin: 0; }
  .slide-lede {
    margin-top: 56px;
    max-width: 50ch;
    color: var(--ink);
  }

  .hero-cta {
    margin-top: 80px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
  }

  .block .h2 { max-width: 22ch; }
  .block > .wrap > .lede { margin-top: 16px; max-width: 50ch; }

  .services {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 64px;
  }
  .services > li {
    display: grid;
    gap: 20px;
    align-content: start;
  }
  .services .h3 { margin-top: 8px; }
  .services p { max-width: 32ch; margin: 0; }

  /* Stagger reveal across the three cards. */
  .services > li:nth-child(1) { transition-delay: 0ms; }
  .services > li:nth-child(2) { transition-delay: 140ms; }
  .services > li:nth-child(3) { transition-delay: 280ms; }

  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close .h2 {
    max-width: 18ch;
    margin: 0;
  }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 38ch; }
  .close-cta .btn { justify-self: start; }

  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .slide-lede { margin-top: 40px; }
    .hero-cta { margin-top: 56px; }
    .services { grid-template-columns: 1fr; gap: 48px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
