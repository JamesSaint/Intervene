---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VerdictBlock from '../../components/VerdictBlock.astro';
import { markAgda } from '../../lib/marks';

const deliver = [
  { h: 'Failure Exposure Report', p: 'Written at three audience layers: board, risk function, and engineering. The same evidence, read by each level it has to convince.' },
  { h: 'Intervention-readiness verdict', p: 'Before impact, at risk, or after impact. One determination, bound to the conditions observed and the reversibility window assessed.' },
  { h: 'Regulator bundle', p: 'Signed JSON. Ed25519 against a locked engine hash. A regulator can verify it without contacting us.' },
  { h: 'Attestation envelope', p: 'Engine version, input hash, output hash, key id, timestamp, signature. The audit trail that makes the verdict defensible later.' },
];

const isnot = [
  { h: 'Not a maturity model', p: 'No five-point scale that always lands at three. The verdict answers the only question that matters: does the chain complete in time.' },
  { h: 'Not a controls checklist', p: 'Existence of a control is not evidence it works under pressure. AGDA™ measures demonstrated capability, not documented intent.' },
  { h: 'Not our opinion', p: 'The engine is deterministic. Same inputs, same outputs. The verdict does not move because the assessor changed.' },
];

const faqs = [
  {
    question: 'What does AGDA™ measure?',
    answer: 'AGDA™ measures Intervention Readiness: whether an organisation can detect, escalate, decide and intervene before harm becomes irreversible.',
  },
  {
    question: 'Is AGDA™ an AI governance framework?',
    answer: 'No. AGDA™ is not an AI governance framework. It measures whether governance can actually intervene when required.',
  },
  {
    question: 'How does AGDA™ produce a verdict?',
    answer: 'AGDA™ evaluates evidence across Detect, Escalate, Decide and Intervene, applies deterministic rules, and returns a signed verdict.',
  },
  {
    question: 'How is AGDA™ related to Intervention Readiness?',
    answer: 'Intervention Readiness is the category. AGDA™ is the deterministic assessment instrument that measures it.',
  },
];
---

<BaseLayout
  title="AGDA™ · A deterministic assessment of Intervention Readiness"
  description="AGDA™ measures whether an organisation can detect, escalate, decide and intervene before harm becomes irreversible. The output is deterministic, signed and independently verifiable."
  current="agda"
  faqs={faqs}
>
  <section class="hero">
    <div class="wrap">
      <span class="label">The instrument</span>
      <h1 class="h1 reveal"><span class="agda-mark">AGDA<span class="agda-tm">™</span></span> measures Intervention Readiness.</h1>
      <p class="lede muted reveal">
        A deterministic assessment of whether an organisation can detect,
        escalate, decide and intervene before harm becomes irreversible. Same
        inputs, same result. Signed for independent verification.
      </p>
      <div class="hero-cta reveal">
        <a href="/Intervene/sample-report/" class="btn">View sample verdict</a>
        <a href="/Intervene/methodology/" class="btn-ghost">How <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> works</a>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">An instrument, <em>not a governance framework.</em></h2>
      <p class="body">
        Audit tells you whether a control existed. Model risk tells you whether
        a model behaves. Governance reviews tell you whether responsibilities
        have been assigned. None of those, by itself, tells you whether humans
        can still intervene inside the time available.
      </p>
      <p class="body muted">
        That is <a href="/Intervene/intervention-readiness/" class="link">Intervention Readiness</a>: the measured capability to
        detect, escalate, decide and intervene before harm becomes irreversible.
      </p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">One question. <em>One signed verdict.</em></h2>
      <p class="lede muted">
        <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> measures the intervention chain, Detect to Escalate to Decide to
        Intervene, against a reversibility window. It returns one of three
        states, signed so a regulator, audit committee or internal assurance
        team can confirm it independently.
      </p>
      <div class="verdict-stage">
        <VerdictBlock />
      </div>
      <a href="/Intervene/methodology/" class="link verdict-more">How <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> works</a>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">What an assessment <em>delivers.</em></h2>
      <ul class="deliver" role="list">
        {deliver.map((d) => (
          <li>
            <h3 class="h3">{d.h}</h3>
            <p class="body muted">{d.p}</p>
          </li>
        ))}
      </ul>
      <a href="/Intervene/sample-report/" class="services-link">See a redacted sample report <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">What <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> <em>is not.</em></h2>
      <div class="card-grid isnot-grid">
        {isnot.map((d) => (
          <div class="card">
            <h3 class="h3 card-title">{d.h}</h3>
            <p class="body-sm muted" set:html={markAgda(d.p)} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <h2 class="h2">Frequently asked questions.</h2>
      <dl class="faq-list">
        {faqs.map((faq) => (
          <div>
            <dt set:html={markAgda(faq.question)} />
            <dd set:html={markAgda(faq.answer)} />
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="block tight">
    <div class="wrap-narrow cta-band">
      <h2 class="h2">From measurement to engagement.</h2>
      <p class="body muted">
        The commercial unit is the assessment, not the seat. Before that,
        inspect the evidence format and the measurement basis.
      </p>
      <div class="cta">
        <a href="/Intervene/sample-report/" class="btn">View sample verdict</a>
        <a href="/Intervene/services/" class="btn-ghost">Levels of assurance</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .label { margin-bottom: 24px; }
  .hero .h1 { max-width: 24ch; }
  .hero .lede { margin-top: 32px; max-width: 58ch; }
  .hero-cta { margin-top: 48px; display: flex; gap: 16px; flex-wrap: wrap; }

  .block .h2 { max-width: 26ch; }
  .block .lede { margin-top: 16px; max-width: 56ch; }
  .wrap-narrow .body { max-width: 62ch; margin: 0 0 16px; }

  .verdict-stage { margin-top: 48px; display: flex; justify-content: flex-start; max-width: 760px; }
  .verdict-more { display: inline-block; margin-top: 32px; font-size: 15px; }

  .deliver {
    list-style: none;
    margin: 64px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 64px;
    border-top: 1px solid var(--hair-strong);
    padding-top: 40px;
  }
  .deliver > li { display: grid; gap: 12px; align-content: start; }
  .deliver p { max-width: 44ch; margin: 0; }

  .isnot-grid { margin-top: 56px; }
  .isnot-grid .card-title { margin: 0; }
  .isnot-grid p { margin: 0; }

  .faq-list {
    margin: 56px 0 0;
    border-top: 1px solid var(--hair-strong);
  }
  .faq-list > div {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 48px;
    padding: 28px 0;
    border-bottom: 1px solid var(--hair);
  }
  .faq-list dt {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.35;
    color: var(--ink);
  }
  .faq-list dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.62;
    color: var(--muted);
  }

  .services-link {
    display: inline-block;
    margin-top: 48px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    border-bottom: 1px solid var(--hair-strong);
    padding-bottom: 2px;
    transition: border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .services-link:hover { border-color: var(--accent); }

  .cta-band .body { margin: 16px 0 32px; max-width: 56ch; }
  .cta-band .cta { display: flex; flex-wrap: wrap; gap: 16px; }

  @media (max-width: 880px) {
    .hero { padding-top: 88px; padding-bottom: 88px; }
    .deliver { grid-template-columns: 1fr; gap: 40px; }
    .faq-list > div { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
