---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProofMarks from '../../components/ProofMarks.astro';
import { markAgda } from '../../lib/marks';

const bundleFields = [
  { k: 'attestationVersion', v: 'The attestation envelope schema version. Current production format: 1.2.' },
  { k: 'engineVersion',      v: 'The AGDA™ engine semver. Pinned at the assessment.' },
  { k: 'engineHash',         v: 'SHA-256 over the canonical AGDA™ engine source-file set and their content hashes.' },
  { k: 'transformVersion',   v: 'Transform identity for the assessed output. N/A for the core SEDI engine.' },
  { k: 'catalogueVersion',   v: 'Failure-mode catalogue version used by the assessment.' },
  { k: 'methodologyVersion', v: 'Methodology version stamped on the result and bound into the attestation.' },
  { k: 'rubricVersion',      v: 'Rubric version stamped on the result and bound into the attestation.' },
  { k: 'keyId',              v: 'Date-stamped Ed25519 key identifier matched to the public key in the manifest registry.' },
  { k: 'scoredAt',           v: 'ISO-8601 UTC timestamp. The moment of attestation.' },
  { k: 'inputHash',          v: 'SHA-256 of the canonical input record. Includes the fact model.' },
  { k: 'outputHash',         v: 'SHA-256 of the canonical AGDA™ result payload, excluding the attestation field.' },
  { k: 'manifestHash',       v: 'SHA-256 of the resolved engine manifest, binding key, catalogue and engine identity together.' },
  { k: 'signature',          v: 'Base64 Ed25519 signature over the canonical attestation envelope, excluding the signature field.' },
];

const audiences = [
  { h: 'Audit committee.', p: 'Confirm that the verdict the chair is being asked to rely on is bound to a specific engine version and a specific set of inputs. No vendor trust required.' },
  { h: 'Internal audit.',  p: 'Run the packaged agda-verify CLI in your own environment. Compare hashes, manifest and signature against the bundle. Pass or fail is mechanical.' },
  { h: 'Regulator.',       p: 'Take the bundle from the supervised entity. Verify in the regulator estate. Independent of any conversation with us or with the entity.' },
];
---

<BaseLayout
  title="Verify an AGDA™ Verdict · Intervene"
  description="Formal AGDA™ Intervention Readiness verdicts ship with a signed regulator bundle. Verify the verdict locally using the packaged agda-verify CLI."
  current="verify"
>
  <section class="hero">
    <div class="wrap">
      <h1 class="h1 reveal">
        Verify the verdict <em>without us.</em>
      </h1>
      <p class="lede muted reveal">
        Formal <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> Intervention Readiness verdicts ship with a signed JSON
        regulator bundle. The verify command runs locally under Node.js 18+.
        You do not depend on us to read what we produced for you.
      </p>
      <div class="hero-proof reveal"><ProofMarks /></div>
    </div>
  </section>

  <!-- THE BUNDLE -->
  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">What's in the bundle.</h2>
      <p class="lede muted">
        A regulator bundle contains the signed result, reconstructed input,
        resolved manifest, verification result and attestation envelope. The
        Ed25519 signature covers the canonical envelope. The envelope commits
        to the input hash, output hash and manifest hash.
      </p>

      <pre class="envelope" aria-label="Regulator bundle example"><code>{`{
  "attestationVersion": "1.2",
  "engineVersion":      "2.0.6",
  "engineHash":         "17594a80a72888a18e8b2c40b6e2fddaf56989f0bb417bc884111f8260355e50",
  "transformVersion":   "N/A",
  "catalogueVersion":   "1.0",
  "methodologyVersion": "1.3.0",
  "rubricVersion":      "1.3.0",
  "keyId":              "2026-05-02-d7e5468e",
  "scoredAt":           "2026-05-14T09:47:12.334Z",
  "inputHash":          "47a2e19c41d4...cd8b103e4f8d",
  "outputHash":         "91f4c02a6800...a6d0d4e7ad91",
  "manifestHash":       "36b45cbe3e7cc74368febfb01db81bb23c792d1c4884e0cff0983e533edc1c12",
  "signature":          "M4Gb2ZqAfD...pLQX7w=="
}`}</code></pre>

      <dl class="fields">
        {bundleFields.map((f) => (
          <div>
            <dt class="mono">{f.k}</dt>
            <dd set:html={markAgda(f.v)}></dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- HOW TO VERIFY -->
  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">How to verify.</h2>
      <p class="lede muted">
        A single command. A pinned key ID. A local verifier the supervised
        entity does not control.
      </p>

      <pre class="cmd" aria-label="Verify command"><code>$ agda-verify --key-id 2026-05-02-d7e5468e --bundle ./bundle.json
[verify] result:
  attestation present: ✓ yes
  manifest found:      ✓ yes
  manifest integrity:  ✓ yes
  signature valid:     ✓ yes
  output integrity:    ✓ yes
  input integrity:     ✓ yes
  revocation checked:  ✓ yes
  revoked:             ✓ no

  ✓ ATTESTATION VALID</code></pre>

      <p class="body muted note">
        The verifier ships as the <span class="mono">agda-verify</span> package command: a
        self-contained Node.js CLI for Node 18+. It verifies the bundle and
        registry locally, using compiled JavaScript, public keys and manifest
        data from the customer distribution. It never contacts Intervene
        infrastructure.
      </p>
    </div>
  </section>

  <!-- PUBLIC KEY CHAIN -->
  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">Public keys and registry.</h2>
      <p class="lede muted">
        Public keys ship with the verifier package. Engine manifests and
        signed revocations are recorded in the append-only registry used by
        the verifier. Historical public keys remain available so historical
        attestations can still be checked.
      </p>

      <dl class="fields">
        <div>
          <dt class="mono">Key material</dt>
          <dd>public-keys/. Ed25519 public keys only.</dd>
        </div>
        <div>
          <dt class="mono">Registry</dt>
          <dd>engine-registry.jsonl. Append-only engine manifests and signed revocation entries.</dd>
        </div>
        <div>
          <dt class="mono">Rotation</dt>
          <dd>Keys may rotate for scheduled rotation, suspected compromise or engine-version retirement.</dd>
        </div>
        <div>
          <dt class="mono">Revocation</dt>
          <dd>Signed revocation entries in the registry or bundle. The verifier honours only revocations with a valid registry signature.</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- WHO VERIFIES -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Three audiences. <em>One verify path.</em></h2>
      <p class="lede muted">
        The same bundle. The same command. The same answer in three places
        that would otherwise have to trust each other.
      </p>

      <ul class="audiences" role="list">
        {audiences.map((a) => (
          <li>
            <h3 class="h3">{a.h}</h3>
            <p class="body muted">{a.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- POSITION -->
  <section class="block">
    <div class="wrap-narrow">
      <h2 class="h2">Why this is the load-bearing claim.</h2>
      <p class="body">
        Big-4 advisories produce PDFs. GRC platforms produce dashboards.
        Neither is reproducible. Neither is independently verifiable. The same
        inputs do not always produce the same output, and the recipient must
        trust the producer to read what the producer produced.
      </p>
      <p class="body muted">
        <span class="agda-mark">AGDA<span class="agda-tm">™</span></span>'s verify path is the property that makes an Intervention Readiness verdict defensible
        in an examination, not just credible in a boardroom. If you cannot
        verify in your own environment, the artefact has not done its job.
      </p>
      <p class="body aside">
        Opinion is not reproducible. The computation is reproducible; the
        signed artefact is independently verifiable.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="block tight">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2">Want to see what a verdict looks like?</h2>
        <div class="close-cta">
          <p class="body muted">
            The sample verdict includes a redacted historical attestation
            summary. Current assessments ship a full bundle bound to your own
            assessed system.
          </p>
          <div class="cta-row">
            <a href="/sample-report/" class="btn">View sample verdict</a>
            <a href="/contact/" class="btn-ghost">Book a conversation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .h1 { max-width: 20ch; }
  .hero .lede { margin-top: 32px; max-width: 56ch; }
  .hero-proof { margin-top: 36px; }

  .block .h2 { max-width: 28ch; }
  .block .lede { margin-top: 16px; max-width: 56ch; }

  .envelope,
  .cmd {
    margin: 48px 0 0;
    padding: 32px;
    background: var(--paper-soft);
    border: 1px solid var(--hair);
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink);
    overflow-x: auto;
    white-space: pre;
  }
  .cmd {
    background: var(--paper-mid);
    color: var(--ink);
    border-color: var(--hair-strong);
  }

  .fields {
    margin: 48px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--hair-strong);
  }
  .fields > div {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid var(--hair);
    align-items: baseline;
  }
  .fields dt {
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .fields dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    line-height: 1.55;
  }

  .note {
    margin-top: 32px;
    max-width: 76ch;
  }

  .audiences {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 56px;
    border-top: 1px solid var(--hair-strong);
    padding-top: 32px;
  }
  .audiences > li { display: grid; gap: 12px; align-content: start; }
  .audiences p { max-width: 36ch; margin: 0; }

  .aside {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    font-style: italic;
    max-width: 56ch;
  }

  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close-grid .h2 { max-width: 24ch; margin: 0; }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 42ch; }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .audiences { grid-template-columns: 1fr; gap: 40px; }
    .fields > div { grid-template-columns: 1fr; gap: 4px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
    .envelope, .cmd { padding: 20px; font-size: 11.5px; }
  }
</style>
