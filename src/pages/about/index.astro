---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LinkedInButton from '../../components/LinkedInButton.astro';
import { markAgda } from '../../lib/marks';
import { socialLinks } from '../../lib/social';

const commitments = [
  { h: 'Independent judgement.',         p: 'No vendor affiliation, no referral fees, no co-marketing. We do not implement what we recommend.' },
  { h: 'Published methodology.',         p: 'Theses, catalogues, corpus governance and rater protocols are public and citeable. Populated-corpus and outcome-validation evidence is supplied separately.' },
  { h: 'Verifiable computation.',        p: 'Formal AGDA™ SEDI assessment verdicts carry Ed25519 attestation. Inputs and outputs are hashed. An audit committee can verify without contacting us.' },
  { h: 'Refusal of false control.',      p: 'If the evidence does not support green, the engine will not produce green. Findings the client did not want, in writing, before the regulator does.' },
];

const sectorsPrimary = [
  { h: 'UK-regulated financial services.', p: 'Banks, asset managers, insurers under PRA / FCA jurisdiction with material automated decision systems.' },
  { h: 'EU high-risk AI operators.',       p: 'Annex III high-risk systems under the EU AI Act, where human oversight must be capable of intervention.' },
  { h: 'Critical national infrastructure.', p: 'Energy, water, telecoms, transport. Operators where intervention failure compounds across dependency chains.' },
];

const sectorsInvite = [
  { h: 'Healthcare systems.',  p: 'Clinical decision support and diagnostic AI. By invitation, where independence from device vendors can be guaranteed.' },
  { h: 'Defence & intelligence.', p: 'Autonomous decision systems and human-on-the-loop frameworks. With appropriate clearances and engagement letters.' },
];

const notServed = [
  { h: 'Not a compliance dashboard.',     p: 'Compliance tools handle evidence management. We measure whether intervention capability holds under stress.' },
  { h: 'Not a Big-4 advisory.',           p: 'No leveraged teams, no slide decks, no implementation arm. Formal SEDI assessments include a signed regulator bundle.' },
  { h: 'Not a policy-writing practice.',  p: 'We do not draft your automation policy. We measure whether the controls behind it produce what the policy claims.' },
  { h: 'Not a model-testing lab.',        p: 'Red-team labs test models. We test whether the chain around the model can act on what the lab finds.' },
  { h: 'Not an implementation partner.',  p: 'No standing-up of controls, no platform integration, no runbook ops. Remediation belongs to you or someone else.' },
  { h: 'Not a safety research practice.', p: 'Operational, not philosophical. A verdict on a specific system, not a paper on risk in general.' },
];
---

<BaseLayout
  title="Why Intervention Readiness Matters · Intervene"
  description="Why Intervention Readiness exists: systems are becoming more capable, organisations rely more on automation, and human oversight only matters if intervention remains possible."
  current="about"
  ogImage="/assets/og/og-about.png"
  pageType="AboutPage"
>
  <section class="hero">
    <div class="wrap">
      <span class="label">Why it matters</span>
      <h1 class="h1 reveal">Capability moved faster than intervention.</h1>
      <p class="lede muted reveal">
        AI systems are becoming more capable. Organisations are becoming more
        dependent on automation. Human oversight only matters if intervention
        remains possible.
      </p>
    </div>
  </section>

  <!-- FOUNDER NARRATIVE -->
  <section class="block">
    <div class="wrap">
      <div class="founder">
        <figure class="portrait reveal">
          <img
            src="/assets/images/james-saint.jpg"
            alt="James Saint, Founder and Principal Advisor, Intervene"
            width="640"
            height="800"
            loading="lazy"
            decoding="async"
          />
          <figcaption>James Saint · London · 2026</figcaption>
          <p class="collab">
            Intervene's methodology is developed in academic collaboration with
            Prof. Nicholas Ryman-Tubb, University of Surrey, with corpus
            governance for regulated automation and intervention failure modes.
          </p>
        </figure>

        <div class="bio reveal">
          <div class="founder-meta">
            <p class="mono role">Founder · Principal Advisor</p>
            <LinkedInButton href={socialLinks.jamesSaintLinkedIn} label="James Saint on LinkedIn" />
          </div>

          <p class="body q">
            Most organisations can evidence governance. Far fewer can prove
            they can intervene in time.
          </p>

          <p class="body">
            My background spans more than three decades across technology,
            systems architecture, digital products, payments, operational
            systems and organisational risk, including co-founding the
            Institute of Financial Innovation in Transactions and Security
            (IFTS).
          </p>

          <p class="body">
            Across that work, the same pattern kept appearing: controls,
            reporting and governance structures existed, but intervention did
            not. Problems were detected too late, escalation stalled, decisions
            drifted and ownership became unclear.
          </p>

          <p class="body">
            AI makes that gap more consequential. Systems can act faster,
            affect more people and create outcomes that become harder to
            reverse. Regulators increasingly require effective human oversight;
            boards need confidence that action remains possible before the
            window closes.
          </p>

          <p class="body">
            That gap became the foundation of <span class="agda-mark">AGDA<span class="agda-tm">™</span></span>. Rather than assessing
            whether controls exist on paper, <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> measures Intervention
            Readiness: whether an organisation can detect, escalate, decide and
            intervene within the time available. The result is a deterministic,
            board-ready verdict. Formal SEDI assessments are supported by a
            signed regulator bundle and cryptographic attestation.
          </p>

          <p class="body">
            Today, through Intervene, I work with organisations that need a
            clear answer to a difficult question:
          </p>

          <p class="body aside keep-together">Can you stop it in time?</p>

          <p class="body">
            Because when the answer matters most, assumptions are not enough.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMITMENTS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">The operating commitments behind the instrument.</h2>
      <p class="lede muted">
        Operating constraints, codified into how we accept work, how we
        calibrate, what we will and will not deliver.
      </p>

      <ul class="commitments" role="list">
        {commitments.map((c) => (
          <li>
            <h3 class="h3">{c.h}</h3>
            <p class="body muted">{c.p}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTORS -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">Where the category is most urgent.</h2>
      <p class="lede muted">
        Three primary sectors. Two by invitation. Some we deliberately do
        not serve.
      </p>

      <div class="sector-group">
        <span class="mono group-label">Primary</span>
        <ul class="sectors three" role="list">
          {sectorsPrimary.map((s) => (
            <li>
              <h3 class="h3">{s.h}</h3>
              <p class="body muted">{s.p}</p>
            </li>
          ))}
        </ul>
      </div>

      <div class="sector-group">
        <span class="mono group-label">By invitation</span>
        <ul class="sectors two" role="list">
          {sectorsInvite.map((s) => (
            <li>
              <h3 class="h3">{s.h}</h3>
              <p class="body muted">{s.p}</p>
            </li>
          ))}
        </ul>
      </div>

      <div class="sector-group not-served">
        <span class="mono group-label">Not currently served</span>
        <p class="body muted not-text">
          Consumer internet, enterprise productivity, B2B SaaS, advertising
          tech. Not because the work is unimportant, but because Intervene's
          methodology, corpus governance and rater protocol are designed for
          regulated, board-accountable systems.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE ARE NOT -->
  <section class="block">
    <div class="wrap">
      <h2 class="h2">What we <em>are not.</em></h2>
      <p class="lede muted">
        About the practice, not the product. (For product-category boundaries,
        see <a href="/services/#what-agda-is-not" class="link">What <span class="agda-mark">AGDA<span class="agda-tm">™</span></span> is not</a> on Services.) Good practices occupy the adjacent
        ground. Knowing the difference avoids procurement confusion later.
      </p>

      <ul class="not-list" role="list">
        {notServed.map((n) => (
          <li>
            <h3 class="h3">{n.h}</h3>
            <p class="body muted" set:html={markAgda(n.p)} />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="block tight">
    <div class="wrap">
      <div class="close-grid">
        <h2 class="h2 reveal">The question returns to the same place.</h2>
        <div class="close-cta reveal">
          <p class="body muted">
            <span class="keep-together">Can you stop it in time?</span> See the evidence format before opening a
            commercial conversation.
          </p>
          <div class="cta-row">
            <a href="/sample-report/" class="btn">View sample verdict</a>
            <a href="/contact/" class="btn-ghost">Book a conversation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 144px;
    padding-bottom: 144px;
    border-bottom: 1px solid var(--hair);
  }
  .hero .label { margin-bottom: 24px; }
  .hero .h1 { max-width: 24ch; }
  .hero .lede { margin-top: 32px; max-width: 52ch; }

  .block .h2 { max-width: 24ch; }
  .block .lede { margin-top: 16px; max-width: 56ch; }

  /* Founder */
  .founder {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 80px;
    align-items: start;
  }
  .portrait {
    margin: 0;
    display: grid;
    gap: 16px;
  }
  .portrait img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(1);
    transition: filter 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .portrait:hover img { filter: grayscale(0); }
  .portrait figcaption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .bio { display: grid; gap: 16px; align-content: start; }
  .bio .h2 { margin: 0; }
  .founder-meta {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .bio .role {
    color: var(--muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 11px;
  }
  .bio .body { margin: 8px 0 0; max-width: 56ch; }
  .bio .q { font-style: italic; }

  .collab {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 40ch;
  }

  .specs {
    margin: 32px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    display: grid;
    gap: 16px;
  }
  .specs > div {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .specs dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .specs dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink);
  }

  /* Aside quote */
  .aside {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--hair);
    font-style: italic;
    max-width: 60ch;
  }

  /* Commitments */
  .commitments {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px 80px;
  }
  .commitments > li { display: grid; gap: 12px; }
  .commitments p { max-width: 44ch; margin: 0; }

  /* Sectors */
  .sector-group { margin-top: 64px; }
  .sector-group:first-of-type { margin-top: 80px; }
  .group-label {
    display: block;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--hair);
  }
  .sectors {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 48px 64px;
  }
  .sectors.three { grid-template-columns: 1fr 1fr 1fr; }
  .sectors.two   { grid-template-columns: 1fr 1fr; }
  .sectors > li  { display: grid; gap: 12px; }
  .sectors p     { max-width: 36ch; margin: 0; }
  .not-served    { padding-top: 24px; }
  .not-text      { max-width: 76ch; margin: 0; }

  /* Not list (what we are not) */
  .not-list {
    list-style: none;
    margin: 80px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    column-gap: 48px;
    border-top: 1px solid var(--hair);
  }
  .not-list > li {
    padding: 32px 0;
    border-bottom: 1px solid var(--hair);
    display: grid;
    gap: 12px;
    align-content: start;
  }
  .not-list p { max-width: 32ch; margin: 0; }

  /* Close */
  .close-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 96px;
    align-items: start;
  }
  .close-grid .h2 { max-width: 24ch; margin: 0; }
  .close-cta {
    display: grid;
    gap: 24px;
    align-content: start;
    padding-top: 12px;
  }
  .close-cta .body { margin: 0; max-width: 38ch; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
  .close-cta .btn { justify-self: start; }

  @media (max-width: 880px) {
    .hero { padding-top: 96px; padding-bottom: 96px; }
    .founder { grid-template-columns: 1fr; gap: 48px; }
    .commitments { grid-template-columns: 1fr; gap: 48px; }
    .sectors.three, .sectors.two { grid-template-columns: 1fr; gap: 40px; }
    .not-list { grid-template-columns: 1fr 1fr; }
    .specs > div { grid-template-columns: 1fr; gap: 4px; }
    .close-grid { grid-template-columns: 1fr; gap: 48px; }
  }
  @media (max-width: 560px) {
    .not-list { grid-template-columns: 1fr; }
  }
</style>
