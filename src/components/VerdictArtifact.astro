---
import ProofMarks from './ProofMarks.astro';
/**
 * The signed AGDA verdict. The visual memory of the instrument and the
 * only place colour appears: three signal dots for the three states.
 * Built to read as a real signed assessment object, not a card.
 */
const states = [
  { key: 'before', code: 'Before impact', line: 'Intervention completes in time. You have room to move.' },
  { key: 'risk',   code: 'At risk',       line: 'Completes within a margin ordinary pressure can erode.' },
  { key: 'after',  code: 'After impact',  line: 'Intervention lands too late. The harm is already irreversible.' },
];
---

<figure
  class="verdict-artifact"
  aria-label="AGDA intervention readiness verdict. Every assessment returns exactly one of three signed states: before impact, at risk, or after impact."
>
  <div class="va-head">
    <span class="va-id mono">AGDA · Intervention readiness</span>
    <span class="va-signed mono"><span class="va-seal" aria-hidden="true"></span>Signed</span>
  </div>

  <ol class="va-states" role="list">
    {states.map((s) => (
      <li class="va-state" data-state={s.key}>
        <span class="va-dot" aria-hidden="true"></span>
        <span class="va-code mono">{s.code}</span>
        <span class="va-line">{s.line}</span>
      </li>
    ))}
  </ol>

  <div class="va-foot">
    <ProofMarks />
    <dl class="va-meta mono">
      <div><dt>engineHash</dt><dd>sha256:b2c8a1d…e7f2916</dd></div>
      <div><dt>signature</dt><dd>ed25519:M4Gb2ZqAfD…pLQX7w</dd></div>
      <div><dt>scoredAt</dt><dd>2026-05-14T09:47:12Z</dd></div>
      <div><dt>keyId</dt><dd>2026-04-22-1e7c3c2c</dd></div>
    </dl>
  </div>

  <figcaption class="va-caption">
    Every assessment returns exactly one of these three, signed and timestamped.
  </figcaption>
</figure>

<style>
  .verdict-artifact {
    margin: 0;
    max-width: 720px;
    border: 1px solid var(--ink);
    background: var(--paper);
  }

  /* Head: identity plus the single deliberate bronze mark on the page. */
  .va-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 28px;
    border-bottom: 1px solid var(--ink);
  }
  .va-id {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .va-signed {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .va-seal {
    width: 12px;
    height: 12px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    position: relative;
  }
  .va-seal::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* States: the three faces. Signal colour lives only here. */
  .va-states { list-style: none; margin: 0; padding: 0; }
  .va-state {
    display: grid;
    grid-template-columns: 18px minmax(120px, max-content) 1fr;
    gap: 20px;
    align-items: center;
    padding: 26px 28px;
    border-bottom: 1px solid var(--hair);
  }
  .va-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
  }
  .va-state[data-state='before'] .va-dot { background: var(--pass); }
  .va-state[data-state='risk']   .va-dot { background: var(--hold); }
  .va-state[data-state='after']  .va-dot { background: var(--warn); }
  .va-code {
    font-size: clamp(15px, 1.4vw, 18px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 400;
  }
  .va-state[data-state='after'] .va-code { color: var(--warn); }
  .va-line {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    color: var(--muted);
  }

  /* Foot: proof marks plus signed metadata. */
  .va-foot {
    padding: 24px 28px 26px;
    background: var(--paper-soft);
    display: grid;
    gap: 22px;
  }
  .va-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 32px;
  }
  .va-meta > div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .va-meta dt {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted-soft);
  }
  .va-meta dd {
    margin: 0;
    font-size: 11.5px;
    letter-spacing: 0.02em;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .va-caption {
    margin: 20px 0 0;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .va-head { padding: 16px 20px; }
    .va-state {
      grid-template-columns: 14px 1fr;
      gap: 8px 14px;
      padding: 22px 20px;
    }
    .va-line { grid-column: 2 / -1; }
    .va-foot { padding: 22px 20px 24px; }
    .va-meta { grid-template-columns: 1fr; }
  }
</style>
