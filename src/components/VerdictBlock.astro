---
import ProofMarks from './ProofMarks.astro';
/**
 * The Verdict Block. The hero object. A struck, notarised verdict artefact of
 * assay, not a card. The verdict states are carried by numbered evidence
 * rows and restrained signal dots, without decorative geometry.
 */
const states = [
  { state: 'open',      name: 'Before impact', line: 'Intervention completes in time. The window stays open.' },
  { state: 'narrowing', name: 'At risk',       line: 'Completes within a margin ordinary pressure can erode.' },
  { state: 'closed',    name: 'After impact',  line: 'Intervention lands too late. The window has closed.' },
];
---

<figure
  class="verdict-block"
  aria-label="AGDA™ Intervention Readiness verdict. A struck, signed artefact. Every assay returns exactly one of three states: before impact, at risk, or after impact."
>
  <div class="vb-frame">
    <span class="vb-corner tl" aria-hidden="true"></span>
    <span class="vb-corner tr" aria-hidden="true"></span>
    <span class="vb-corner bl" aria-hidden="true"></span>
    <span class="vb-corner br" aria-hidden="true"></span>

    <header class="vb-head">
      <span class="vb-title mono">Intervention Readiness · Verdict</span>
      <span class="vb-serial mono">No. 0001 / 2026</span>
    </header>

    <ol class="vb-states" role="list">
      {states.map((s, i) => (
        <li class="vb-state" data-state={s.state}>
          <span class="vb-index mono">{String(i + 1).padStart(2, '0')}</span>
          <span class="vb-read">
            <span class="vb-name mono"><span class="vb-dot" aria-hidden="true"></span>{s.name}</span>
            <span class="vb-line">{s.line}</span>
          </span>
        </li>
      ))}
    </ol>

    <footer class="vb-foot">
      <dl class="vb-record mono">
        <div><dt>engine</dt><dd>AGDA v2.0.6</dd></div>
        <div><dt>engineHash</dt><dd>17594a80…60355e50</dd></div>
        <div><dt>manifestHash</dt><dd>36b45cbe…3edc1c12</dd></div>
        <div><dt>signature</dt><dd>M4Gb2ZqAfD…pLQX7w==</dd></div>
        <div><dt>scoredAt</dt><dd>2026-05-14T09:47:12Z</dd></div>
        <div><dt>keyId</dt><dd>2026-05-02-d7e5468e</dd></div>
      </dl>
      <div class="vb-strike">
        <span class="vb-seal" aria-hidden="true"></span>
        <span class="vb-struck mono">Struck and signed · independently verifiable</span>
      </div>
      <ProofMarks />
    </footer>
  </div>
  <figcaption class="vb-caption">Every assay returns exactly one of these three, struck and signed.</figcaption>
</figure>

<style>
  .verdict-block { margin: 0; max-width: 760px; }
  .vb-frame {
    position: relative;
    border: 1px solid var(--hair-strong);
    background: var(--paper-soft);
    padding: 0;
  }
  .vb-frame::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 28px;
    width: 112px;
    height: 1px;
    background: var(--accent);
  }
  /* Registration corners: reads as an official verdict artefact. */
  .vb-corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid var(--accent);
  }
  .vb-corner.tl { top: 7px; left: 7px; border-right: 0; border-bottom: 0; }
  .vb-corner.tr { top: 7px; right: 7px; border-left: 0; border-bottom: 0; }
  .vb-corner.bl { bottom: 7px; left: 7px; border-right: 0; border-top: 0; }
  .vb-corner.br { bottom: 7px; right: 7px; border-left: 0; border-top: 0; }

  .vb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 28px;
    border-bottom: 1px solid var(--hair-strong);
  }
  .vb-title { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink); }
  .vb-serial { font-size: 11px; letter-spacing: 0.08em; color: var(--muted); }

  .vb-states { list-style: none; margin: 0; padding: 0; }
  .vb-state {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 28px;
    align-items: start;
    padding: 24px 28px;
    border-bottom: 1px solid var(--hair);
    transition: background var(--dur-hover) var(--ease);
  }
  .vb-state:hover { background: var(--accent-faint); }
  .vb-index {
    color: var(--accent);
    font-size: 12px;
    letter-spacing: 0.18em;
    padding-top: 3px;
  }
  .vb-read { display: grid; gap: 8px; }
  .vb-name {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: clamp(15px, 1.4vw, 18px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .vb-dot { width: 10px; height: 10px; flex: none; }
  .vb-state[data-state='open']      .vb-dot { background: var(--pass); }
  .vb-state[data-state='narrowing'] .vb-dot { background: var(--hold); }
  .vb-state[data-state='closed']    .vb-dot { background: var(--warn); }
  .vb-state[data-state='closed']    .vb-name { color: var(--warn); }
  .vb-line { font-family: var(--font-sans); font-size: 15px; line-height: 1.5; color: var(--muted); }

  .vb-foot { padding: 24px 28px 26px; background: var(--paper-mid); display: grid; gap: 20px; }
  .vb-record { margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 9px 32px; }
  .vb-record > div { display: grid; grid-template-columns: 92px 1fr; gap: 12px; align-items: baseline; }
  .vb-record dt { font-size: 11px; letter-spacing: 0.04em; color: var(--muted-soft); }
  .vb-record dd { margin: 0; font-size: 11.5px; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .vb-strike { display: flex; align-items: center; gap: 12px; padding-top: 18px; border-top: 1px solid var(--hair); }
  .vb-seal {
    width: 18px; height: 18px; border: 1px solid var(--accent); position: relative; flex: none;
  }
  .vb-seal::after { content: ''; position: absolute; inset: 4px; background: var(--accent); }
  .vb-struck { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }

  .vb-caption { margin: 20px 0 0; font-family: var(--font-sans); font-size: 13px; color: var(--muted); }

  @media (max-width: 640px) {
    .vb-head { padding: 16px 20px; }
    .vb-state { grid-template-columns: 44px 1fr; gap: 14px; padding: 22px 20px; }
    .vb-foot { padding: 22px 20px 24px; }
    .vb-record { grid-template-columns: 1fr; }
  }
</style>
