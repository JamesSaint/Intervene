---
/**
 * The Hallmark. The persistent brand mark, struck like a row of assay
 * punches: the maker (AGDA™), the assay serial, and a struck seal. Travels
 * in the footer of every page and beside references to formal SEDI verdicts.
 */
interface Props {
  serial?: string;
}
const { serial = 'Assay · 2026' } = Astro.props;
---

<span class="hallmark" role="img" aria-label="AGDA™ hallmark: struck mark for formal SEDI assessment bundles.">
  <span class="hm-cell hm-word mono"><span class="agda-mark">AGDA<span class="agda-tm">™</span></span></span>
  <span class="hm-cell hm-serial mono">{serial}</span>
  <span class="hm-cell hm-seal"><span class="seal" aria-hidden="true"></span></span>
</span>

<style>
  .hallmark {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--hair-strong);
    background: var(--paper);
  }
  .hm-cell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 11px;
    border-right: 1px solid var(--hair-strong);
  }
  .hm-cell:last-child { border-right: 0; }
  .hm-word { font-size: 11px; letter-spacing: 0.14em; color: var(--ink); }
  .hm-serial { font-size: 11px; letter-spacing: 0.06em; color: var(--muted); text-transform: uppercase; }
  .seal {
    width: 12px;
    height: 12px;
    border: 1px solid var(--accent);
    position: relative;
  }
  .seal::after {
    content: '';
    position: absolute;
    inset: 3px;
    background: var(--accent);
  }
</style>
