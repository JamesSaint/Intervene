---
interface Props {
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  inverted?: boolean;
  href?: string | null;
  label?: string;
}

const {
  size = 'sm',
  inverted = false,
  href = '/',
  label = 'Intervene · home',
} = Astro.props;

const sizes = {
  xs: { word: 16 },
  sm: { word: 22 },
  md: { word: 32 },
  lg: { word: 56 },
  xl: { word: 96 },
};

const s = sizes[size];
const Tag = href ? 'a' : 'span';
---

<Tag
  class:list={['intervene-logo', { inverted }]}
  href={href ?? undefined}
  aria-label={href ? label : undefined}
  style={`--word: ${s.word}px;`}
>
  <span class="intervene-wordmark">intervene</span>
</Tag>

<style>
  .intervene-logo {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
    line-height: 1;
    transition: color var(--dur-hover) var(--ease-state);
  }
  .intervene-logo.inverted { color: var(--inverse-ink); }

  .intervene-wordmark {
    font-family: var(--font-sans);
    font-size: var(--word);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 0.9;
  }

  a.intervene-logo:hover { color: var(--bronze); }
</style>
