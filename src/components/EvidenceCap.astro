---
const grades = [
  { label: 'Assumed',       ceiling: 1 },
  { label: 'Policy',        ceiling: 2 },
  { label: 'Drill',         ceiling: 3 },
  { label: 'Production',    ceiling: 4 },
  { label: 'Stress-tested', ceiling: 5 },
];
const MAX = 5;
---

<figure class="ev-cap reveal" aria-label="Evidence-grade ceiling. Policy alone caps at 2 of 5.">
  <div class="chart">
    <div class="scale" aria-hidden="true">
      {[1, 2, 3, 4, 5].map((n) => (
        <span class="tick" style={`left: ${(n / MAX) * 100}%`}>{n}</span>
      ))}
    </div>

    <div class="rows">
      <div class="gridlines" aria-hidden="true">
        {[1, 2, 3, 4, 5].map((n) => (
          <span class="gridline" style={`left: ${(n / MAX) * 100}%`}></span>
        ))}
      </div>

      {grades.map((g, i) => (
        <div class="row" style={`--w: ${(g.ceiling / MAX) * 100}%; --delay: ${i * 100}ms`}>
          <span class="grade-label">{g.label}</span>
          <span class="track">
            <span class="bar"></span>
          </span>
          <span class="cap-text">caps at {g.ceiling} / {MAX}</span>
        </div>
      ))}
    </div>
  </div>
  <figcaption>Policy alone caps at 2 of 5. Green requires evidence the control has worked under real pressure.</figcaption>
</figure>

<style>
  .ev-cap {
    margin: 80px 0 0;
    padding: 0;
    /* parent .reveal is overridden so children animate individually */
    opacity: 1;
    transform: none;
  }

  .chart {
    --left-col: 180px;
    --right-col: 120px;
    --gutter: 24px;
  }

  /* Scale row */
  .scale {
    position: relative;
    height: 28px;
    margin-left: calc(var(--left-col) + var(--gutter));
    margin-right: calc(var(--right-col) + var(--gutter));
    border-bottom: 1px solid var(--ink);
  }
  .tick {
    position: absolute;
    bottom: 6px;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  /* Bar rows */
  .rows {
    position: relative;
    padding-top: 8px;
  }

  /* Vertical gridlines, anchored to the track column. */
  .gridlines {
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--left-col) + var(--gutter));
    right: calc(var(--right-col) + var(--gutter));
    pointer-events: none;
    z-index: 0;
  }
  .gridline {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--hair-soft);
    transform: translateX(-1px);
  }

  .row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: var(--left-col) 1fr var(--right-col);
    gap: var(--gutter);
    align-items: center;
    padding: 16px 0;
  }
  .grade-label {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }
  .track {
    position: relative;
    display: block;
    height: 22px;
    background: transparent;
  }
  .bar {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0;
    background: var(--ink);
    transition: width 720ms cubic-bezier(0.65, 0, 0.35, 1);
    transition-delay: var(--delay);
  }
  .ev-cap.in .bar { width: var(--w); }

  .cap-text {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    text-align: right;
    letter-spacing: 0.04em;
    opacity: 0;
    transition: opacity 360ms cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: calc(var(--delay) + 480ms);
  }
  .ev-cap.in .cap-text { opacity: 1; }

  figcaption {
    margin-top: 56px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    max-width: 60ch;
  }

  @media (max-width: 720px) {
    .chart { --left-col: 120px; --right-col: 0px; --gutter: 16px; }
    .scale { margin-right: 0; height: 22px; }
    .row {
      grid-template-columns: var(--left-col) 1fr;
      gap: var(--gutter);
      padding: 12px 0;
    }
    .gridlines { right: 0; }
    .cap-text { display: none; }
    .grade-label { font-size: 14px; }
    .track { height: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bar, .cap-text { transition: none !important; }
    .ev-cap .bar { width: var(--w) !important; }
    .ev-cap .cap-text { opacity: 1 !important; }
  }
</style>
