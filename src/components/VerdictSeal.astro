---
/**
 * The signed-verdict mark. The single deliberate bronze element on a
 * page. Mono type, one bronze ring. No fill, no decoration.
 */
interface Props {
  verdict?: string;
  meta?: string;
}
const {
  verdict = 'Signed verdict',
  meta = 'Ed25519 · locked engine hash',
} = Astro.props;
---

<div class="verdict-seal" role="img" aria-label={`${verdict}. ${meta}.`}>
  <span class="seal-mark" aria-hidden="true"></span>
  <span class="seal-text">
    <span class="seal-verdict mono">{verdict}</span>
    <span class="seal-meta mono">{meta}</span>
  </span>
</div>

<style>
  .verdict-seal {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border: 1px solid var(--hair);
    background: var(--paper);
  }
  .seal-mark {
    flex: none;
    width: 18px;
    height: 18px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    position: relative;
  }
  .seal-mark::after {
    content: '';
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    background: var(--accent);
  }
  .seal-text {
    display: grid;
    gap: 3px;
  }
  .seal-verdict {
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
  }
  .seal-meta {
    color: var(--muted);
    letter-spacing: 0.04em;
    font-size: 11px;
  }
</style>
