---
// Animated hamburger that morphs to an X when the parent button has
// aria-expanded="true". Three thin lines. Top and bottom rotate into
// the X; the middle fades out.
---

<span class="menu-icon" aria-hidden="true">
  <span class="line line-1"></span>
  <span class="line line-2"></span>
  <span class="line line-3"></span>
</span>

<style>
  .menu-icon {
    position: relative;
    display: inline-block;
    width: 22px;
    height: 14px;
    flex-shrink: 0;
  }
  .line {
    position: absolute;
    left: 0;
    right: 0;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .line-1 { top: 0; }
  .line-2 { top: 50%; transform: translateY(-50%); }
  .line-3 { bottom: 0; }

  [aria-expanded='true'] .line-1 { transform: translateY(6.25px) rotate(45deg); }
  [aria-expanded='true'] .line-2 { opacity: 0; transform: translateY(-50%) scaleX(0); }
  [aria-expanded='true'] .line-3 { transform: translateY(-6.25px) rotate(-45deg); }

  @media (prefers-reduced-motion: reduce) {
    .line { transition-duration: 80ms; }
  }
</style>
