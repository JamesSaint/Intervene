---
const base = import.meta.env.BASE_URL;
const items = [
  { label: 'Home',          href: `${base}` },
  { label: 'Method',        href: `${base}method/` },
  { label: 'Verify',        href: `${base}verify/` },
  { label: 'Services',      href: `${base}services/` },
  { label: 'Sample report', href: `${base}sample-report/` },
  { label: 'About',         href: `${base}about/` },
  { label: 'Contact',       href: `${base}contact/` },
];
---

<div
  class="takeover"
  id="takeover-menu"
  role="dialog"
  aria-modal="true"
  aria-labelledby="takeover-heading"
  aria-hidden="true"
  hidden
  data-takeover
>
  <nav class="takeover-body wrap" aria-labelledby="takeover-heading">
    <h2 id="takeover-heading" class="sr-only">Primary navigation</h2>
    <ul role="list">
      {items.map((item, i) => (
        <li style={`--i: ${i}`}>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<script>
  const FOCUSABLE = 'a[href],button:not([disabled]),[tabindex]:not([tabindex="-1"])';

  class Takeover {
    constructor(el) {
      this.el = el;
      this.trigger = null;
      this.lastFocused = null;
      this.isOpen = false;
      this.bind();
    }

    bind() {
      document.querySelectorAll('[data-menu-trigger]').forEach((t) => {
        t.addEventListener('click', (e) => {
          e.preventDefault();
          if (this.isOpen) this.close();
          else this.open(t);
        });
      });
      this.el.addEventListener('keydown', (e) => this.onKey(e));
      this.el.querySelectorAll('a[href]').forEach((a) => {
        a.addEventListener('click', () => this.close());
      });
    }

    open(trigger) {
      if (this.isOpen) return;
      this.isOpen = true;
      this.trigger = trigger;
      this.lastFocused = document.activeElement;

      this.el.hidden = false;
      this.el.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      trigger.setAttribute('aria-label', 'Close menu');

      document.querySelector('[data-site-header]')?.setAttribute('data-takeover-open', '');

      Array.from(document.body.children).forEach((c) => {
        if (c !== this.el && !c.hasAttribute('data-site-header')) {
          c.setAttribute('inert', '');
        }
      });
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        this.el.classList.add('open');
        this.el.querySelector('a[href]')?.focus();
      });
    }

    close() {
      if (!this.isOpen) return;
      this.isOpen = false;

      this.el.classList.remove('open');
      this.el.setAttribute('aria-hidden', 'true');
      this.trigger?.setAttribute('aria-expanded', 'false');
      this.trigger?.setAttribute('aria-label', 'Open menu');

      document.querySelector('[data-site-header]')?.removeAttribute('data-takeover-open');

      Array.from(document.body.children).forEach((c) => {
        if (c !== this.el) c.removeAttribute('inert');
      });
      document.body.style.overflow = '';

      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.setTimeout(() => {
        if (!this.isOpen) this.el.hidden = true;
      }, reduce ? 80 : 320);

      this.trigger?.focus();
    }

    onKey(e) {
      if (e.key === 'Escape') {
        e.preventDefault();
        this.close();
        return;
      }
      if (e.key === 'Tab') {
        const items = Array.from(this.el.querySelectorAll(FOCUSABLE)).filter(
          (n) => n.offsetParent !== null
        );
        if (!items.length) return;
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  }

  const el = document.querySelector('[data-takeover]');
  if (el) new Takeover(el);
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .takeover {
    position: fixed;
    top: var(--header-h);
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    background: var(--paper);
    color: var(--ink);
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .takeover.open {
    opacity: 1;
    pointer-events: auto;
  }
  .takeover[hidden] { display: none; }

  .takeover-body {
    flex: 1;
    display: flex;
    align-items: center;
    padding-top: 80px;
    padding-bottom: 80px;
  }
  .takeover-body ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .takeover-body a {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 88px);
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--ink);
    display: inline-block;
    padding: 8px 0;
    transition:
      color 200ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 360ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 360ms cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(12px);
    transition-delay: calc(80ms + var(--i) * 50ms);
  }
  .takeover.open .takeover-body a {
    opacity: 1;
    transform: none;
  }
  .takeover-body a:hover,
  .takeover-body a:focus-visible {
    color: var(--muted);
    outline: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .takeover-body a { transition-delay: 0ms; transform: none; }
  }
</style>
