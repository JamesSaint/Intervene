---
/**
 * The recurring AGDA™ identity. Three proof marks for formal SEDI
 * assessment bundles: deterministic, SEDI signed, bundle-verifiable. Mono,
 * monochrome. Used across the homepage artifact and the inner pages so
 * AGDA™ reads as one system object, not an acronym.
 */
interface Props {
  align?: 'start' | 'center';
}
const { align = 'start' } = Astro.props;
const marks = ['Deterministic', 'SEDI signed', 'Bundle-verifiable'];
---

<ul class={`proof-marks ${align}`} role="list" aria-label="AGDA™ SEDI bundle properties">
  {marks.map((m) => (
    <li class="mono"><span class="tick" aria-hidden="true"></span>{m}</li>
  ))}
</ul>

<style>
  .proof-marks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 28px;
  }
  .proof-marks.center { justify-content: center; }
  .proof-marks > li {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-soft);
  }
  .tick {
    width: 5px;
    height: 5px;
    background: var(--accent);
    flex: none;
  }
  @media (max-width: 560px) {
    .proof-marks { gap: 10px 20px; }
  }
</style>
