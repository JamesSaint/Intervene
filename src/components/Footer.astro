---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap foot-inner">
    <span class="brand">intervene</span>

    <nav aria-label="Footer">
      <ul role="list">
        <li><a href="/Intervene/method/">Method</a></li>
        <li><a href="/Intervene/services/">Services</a></li>
        <li><a href="/Intervene/sample-report/">Sample report</a></li>
        <li><a href="/Intervene/about/">About</a></li>
        <li><a href="/Intervene/contact/">Contact</a></li>
      </ul>
    </nav>

    <span class="meta">© {year} Intervene Group Ltd</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hair);
    padding: 80px 0;
    background: var(--paper);
  }
  .foot-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 48px;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 32px;
    justify-content: center;
  }
  nav a {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink);
    padding-bottom: 1px;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-hover) var(--ease);
  }
  nav a:hover { border-color: var(--ink); }
  .meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
    justify-self: end;
  }
  @media (max-width: 720px) {
    .foot-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: left;
    }
    nav ul { justify-content: flex-start; flex-wrap: wrap; gap: 20px; }
    .meta { justify-self: start; }
  }
</style>
