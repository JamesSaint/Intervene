---
import Hallmark from './Hallmark.astro';
import LinkedInButton from './LinkedInButton.astro';
import { socialLinks } from '../lib/social';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap foot-inner">
    <div class="brand-col">
      <span class="brand">intervene</span>
      <span class="brand-line">Intervention Readiness, measured.</span>
      <div class="brand-social">
        <LinkedInButton href={socialLinks.interveneLinkedIn} label="Intervene Limited on LinkedIn" />
      </div>
      <div class="brand-hallmark"><Hallmark /></div>
    </div>

    <nav class="primary-nav" aria-label="Footer">
      <ul role="list">
        <li><a href="/intervention-readiness/">Intervention Readiness</a></li>
        <li><a href="/about/">Why it matters</a></li>
        <li><a href="/agda/"><span class="agda-mark">AGDA<span class="agda-tm">™</span></span></a></li>
        <li><a href="/methodology/">How it works</a></li>
        <li><a href="/sample-report/">View verdict</a></li>
        <li><a href="/services/">Engage</a></li>
      </ul>
    </nav>

    <div class="meta">
      <span class="meta-name">Intervene Limited</span>
      <span>Owner and developer of <span class="agda-mark">AGDA<span class="agda-tm">™</span></span></span>
      <span>Registered in England and Wales</span>
      <span class="meta-copy">© {year} Intervene Limited</span>
    </div>
  </div>

  <div class="wrap foot-sub">
    <nav class="supporting-nav" aria-label="Supporting">
      <ul role="list">
        <li><a href="/sectors/">Where it matters</a></li>
        <li><a href="/insights/">Insights</a></li>
        <li><a href="/verify/">Verify</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/legal/terms/">Terms</a></li>
        <li><a href="/legal/privacy/">Privacy</a></li>
        <li><a href="/legal/gdpr/">UK GDPR</a></li>
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hair);
    padding: 72px 0 44px;
    background: var(--paper-deep);
  }
  .foot-inner {
    display: grid;
    grid-template-columns: 1.2fr auto 1fr;
    align-items: start;
    gap: 48px;
  }
  .brand-col { display: grid; gap: 12px; align-content: start; }
  .brand-social {
    display: flex;
    align-items: center;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .brand-line {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    max-width: 34ch;
    line-height: 1.5;
  }
  .brand-hallmark { margin-top: 8px; }
  .primary-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }
  .primary-nav a {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-soft);
    white-space: nowrap;
    padding-bottom: 1px;
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--dur-hover) var(--ease),
      color var(--dur-hover) var(--ease);
  }
  .primary-nav a:hover { border-color: var(--accent); color: var(--ink); }
  .meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
    justify-self: end;
    display: grid;
    gap: 2px;
    text-align: right;
    line-height: 1.5;
  }
  .meta-name { color: var(--ink); font-weight: 700; }
  .meta-copy { margin-top: 12px; }

  .foot-sub {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--hair);
  }
  .supporting-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
  }
  .supporting-nav a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-hover) var(--ease);
  }
  .supporting-nav a:hover { color: var(--ink); }

  @media (max-width: 720px) {
    .foot-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: left;
    }
    .meta { justify-self: start; text-align: left; }
    .supporting-nav ul { gap: 16px 20px; }
  }
</style>
