---
import Header from '../components/Header.astro';
import TakeoverMenu from '../components/TakeoverMenu.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  current?: string;
  noindex?: boolean;
  canonicalPath?: string;
  ogImage?: string;
}

const {
  title,
  description,
  current,
  noindex = false,
  canonicalPath = Astro.url.pathname,
  ogImage = '/assets/og/og-home.png',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://jamessaint.github.io';
const base = import.meta.env.BASE_URL;
const canonical = `${site}${canonicalPath}`;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${site}${base}${ogImage.replace(/^\//, '')}`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Intervene Limited',
  url: `${site}${base}`,
  logo: `${site}${base}assets/images/favicons/android-chrome-512x512.png`,
  founder: {
    '@type': 'Person',
    name: 'James Saint',
    jobTitle: 'Founder and Principal Advisor',
  },
  description: 'Most organisations have governance, controls and accountability, but have never measured whether intervention is still possible when it matters. AGDA measures it and signs the verdict.',
  areaServed: ['United Kingdom', 'European Union'],
};
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" href="/Intervene/assets/images/favicons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/Intervene/assets/images/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/Intervene/assets/images/favicons/apple-touch-icon-180x180.png" />
    <link rel="manifest" href="/Intervene/assets/images/favicons/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Intervene" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <slot name="head" />
  </head>
  <body data-current={current}>
    <Header />
    <TakeoverMenu />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <script>
      import { initReveal } from '../lib/reveal.ts';
      initReveal();
    </script>
  </body>
</html>
